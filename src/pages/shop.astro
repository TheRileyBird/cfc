---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import ProductsSection from '../components/ProductsSection.astro';
import Footer from '../components/Footer.astro';
import { getAllProducts } from '../lib/shopify';

const PRODUCTS_PER_PAGE = 16;
const allProducts = await getAllProducts();
const products = allProducts
  .map((product, bestSellingRank) => ({ ...product, bestSellingRank }))
  .sort((a, b) => a.title.localeCompare(b.title));
const totalPages = Math.max(1, Math.ceil(products.length / PRODUCTS_PER_PAGE));
---

<Layout
  title="Shop CFC Skincare — Complete System"
  description="Shop the complete CFC Skincare cleanse, treat, and protect system."
>
  <Nav />
  <main>
    <ProductsSection
      variant="complete"
      products={products}
      pagination={{
        currentPage: 1,
        totalPages,
        totalProducts: products.length,
      }}
    />
  </main>
  <Footer />
</Layout>
