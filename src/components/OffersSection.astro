---
const offers = [
  {
    name: 'Starter System',
    tagline: 'Begin here.',
    price: '$130',
    priceRange: '$110–$130 with Subscribe & Save',
    description: 'One cleanser, one treatment, one SPF. The foundation of the CFC protocol — clinically designed, simple to use, results within weeks.',
    includes: [
      'Age Defying Brightening Cleanser',
      'Apple Stem Wrinkle Eraser',
      'Pure Sun Defense SPF 50+',
    ],
    cta: 'Start Your Skin Journey',
    href: '/shop',
    featured: false,
  },
  {
    name: 'Complete Treatment System',
    tagline: 'The full transformation.',
    price: '$250',
    priceRange: '$175–$210 with Subscribe & Save',
    description: 'The full Cleanse-Treat-Protect protocol. Five products, three steps — this is the system our clients use when they stop wearing foundation.',
    includes: [
      'Brightening Glyco Glow Cleanser',
      'Apple Stem Wrinkle Eraser',
      'Color Correction C&E Serum',
      'Pure Hydration Hyaluronic Acid Serum',
      'Sun Kissed Tinted SPF 30',
    ],
    cta: 'Shop the Complete System',
    href: '/shop',
    featured: true,
  },
  {
    name: 'Premium Collection',
    tagline: 'For women who are serious.',
    price: '$450',
    priceRange: '$315–$420 with Subscribe & Save',
    description: 'The complete system plus advanced NAD+ formulations and the Quad Glow Elite LED Mask. At-home results that rival in-office treatments.',
    includes: [
      'Complete System — all 5 products',
      'NAD+ Age Defying Retinol Cream 0.5%',
      'Revitalizing Retinol Eye Cream',
      'T Tightening and Firming Serum',
      'Quad Glow Elite LED Mask',
    ],
    cta: 'Build Your Premium Routine',
    href: '/shop',
    featured: false,
  },
];
---

<section class="bg-parchment" id="offers" style="padding: 140px 0;">
  <div style="max-width: 1440px; margin: 0 auto; padding: 0 40px;">

    <!-- Header -->
    <div class="reveal text-center mx-auto mb-16" style="max-width: 560px;">
      <div class="flex items-center justify-center gap-4 mb-7">
        <div class="h-px bg-gold" style="width: 24px;"></div>
        <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">Choose Your System</span>
      </div>
      <h2 class="font-display font-light text-ink mb-4" style="font-size: clamp(38px, 4vw, 58px); line-height: 1.0; letter-spacing: -0.02em;">
        Start where<br/>you are.
      </h2>
      <p class="font-sans font-light text-[14px] text-ink-soft">Save 30% when you subscribe — and never run out of what your skin needs.</p>
    </div>

    <!-- Cards grid: 2px gap -->
    <div class="grid grid-cols-1 lg:grid-cols-3" style="gap: 2px;">
      {offers.map(({ name, tagline, price, priceRange, description, includes, cta, href, featured }, i) => (
        <div
          class="reveal relative flex flex-col"
          style={`
            ${featured ? 'background: oklch(13% 0.010 255);' : 'background: oklch(99.5% 0.003 75);'}
            padding: 52px 48px;
            transition-delay: ${i * 100}ms;
          `}
        >
          {featured && (
            <div class="absolute -top-[18px] left-1/2 -translate-x-1/2">
              <span class="bg-gold text-ink font-mono text-[9px] tracking-[0.15em] uppercase px-4 py-1.5 whitespace-nowrap">
                Most Popular
              </span>
            </div>
          )}

          <!-- Tagline -->
          <p class="font-mono text-[10px] tracking-[0.2em] uppercase mb-3" style={featured ? 'color: oklch(64% 0.115 72);' : 'color: oklch(64% 0.115 72);'}>
            {tagline}
          </p>

          <!-- Name -->
          <h3 class="font-display text-[28px] font-normal mb-5" style={featured ? 'color: oklch(99.5% 0.003 75);' : 'color: oklch(13% 0.010 255);'}>
            {name}
          </h3>

          <!-- Divider -->
          <div class="mb-6" style={featured ? 'border-top: 1px solid rgba(255,255,255,0.08);' : 'border-top: 1px solid oklch(88% 0.006 72);'}></div>

          <!-- Price -->
          <div class="mb-5">
            <span
              class="font-display font-light"
              style={`font-size: 52px; line-height: 1; ${featured ? 'color: oklch(99.5% 0.003 75);' : 'color: oklch(13% 0.010 255);'}`}
            >{price}</span>
            <p class="font-mono text-[10px] tracking-[0.1em] mt-2" style={featured ? 'color: rgba(255,255,255,0.4);' : 'color: oklch(50% 0.006 255);'}>
              {priceRange}
            </p>
          </div>

          <!-- Divider -->
          <div class="mb-6" style={featured ? 'border-top: 1px solid rgba(255,255,255,0.08);' : 'border-top: 1px solid oklch(88% 0.006 72);'}></div>

          <!-- Description -->
          <p class="font-sans font-light text-[13px] leading-relaxed mb-7" style={featured ? 'color: rgba(255,255,255,0.6);' : 'color: oklch(50% 0.006 255);'}>
            {description}
          </p>

          <!-- Includes -->
          <ul class="space-y-2.5 mb-8 flex-1">
            {includes.map(item => (
              <li class="flex items-start gap-3 font-sans font-light text-[13px]" style={featured ? 'color: rgba(255,255,255,0.65);' : 'color: oklch(50% 0.006 255);'}>
                <span class="h-px bg-gold shrink-0 mt-2" style="width: 14px;"></span>
                {item}
              </li>
            ))}
          </ul>

          <!-- CTA -->
          <a
            href={href}
            class="block text-center font-mono text-[10px] tracking-[0.18em] uppercase py-4 transition-all duration-200"
            style={featured
              ? 'background: oklch(64% 0.115 72); color: oklch(13% 0.010 255);'
              : 'border: 1px solid oklch(13% 0.010 255); color: oklch(13% 0.010 255);'}
            onmouseover={featured
              ? "this.style.background='oklch(80% 0.08 78)'"
              : "this.style.background='oklch(13% 0.010 255)'; this.style.color='oklch(99.5% 0.003 75)'"}
            onmouseout={featured
              ? "this.style.background='oklch(64% 0.115 72)'"
              : "this.style.background='transparent'; this.style.color='oklch(13% 0.010 255)'"}
          >
            {cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
