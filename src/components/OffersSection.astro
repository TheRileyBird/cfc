---
const offers = [
  {
    name: 'Starter System',
    tagline: 'Begin here.',
    price: '$130',
    priceTo: '150',
    savingsPrice: '$110–$130',
    description: 'One cleanser, one treatment, one SPF. The foundation of the CFC protocol — clinically designed, simple to use, results within weeks.',
    includes: [
      'Age Defying Brightening Cleanser',
      'Apple Stem Wrinkle Eraser',
      'Pure Sun Defense SPF 50+',
    ],
    cta: 'Start Your Skin Journey',
    href: 'https://www.cfcskincare.shop/collections/all',
    featured: false,
  },
  {
    name: 'Complete Treatment System',
    tagline: 'The full transformation.',
    price: '$250',
    priceTo: '300',
    savingsPrice: '$175–$210',
    description: 'The full Cleanse-Treat-Protect protocol. Five products, three steps — this is the system our clients use when they stop wearing foundation.',
    includes: [
      'Brightening Glyco Glow Cleanser',
      'Apple Stem Wrinkle Eraser',
      'Color Correction C&E Serum',
      'Pure Hydration Hyaluronic Acid Serum',
      'Sun Kissed Tinted SPF 30',
    ],
    cta: 'Shop the Complete System',
    href: 'https://www.cfcskincare.shop/collections/all',
    featured: true,
  },
  {
    name: 'Premium Collection',
    tagline: 'For women who are serious.',
    price: '$450',
    priceTo: '600+',
    savingsPrice: '$315–$420',
    description: 'The complete system plus advanced NAD+ formulations and the Quad Glow Elite LED Mask. At-home results that rival in-office treatments.',
    includes: [
      'Complete System — all 5 products',
      'NAD+ Age Defying Retinol Cream 0.5%',
      'Revitalizing Retinol Eye Cream',
      'T Tightening and Firming Serum',
      'Quad Glow Elite LED Mask',
    ],
    cta: 'Build Your Premium Routine',
    href: 'https://www.cfcskincare.shop/collections/all',
    featured: false,
  },
];
---

<section class="bg-white border-t border-slate-100" id="offers">
  <div class="max-w-7xl mx-auto px-6 lg:px-16 py-24 lg:py-32">

    <!-- Header -->
    <div
      x-data
      x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
      class="opacity-0 translate-y-4 transition-all duration-700 text-center max-w-xl mx-auto mb-16 lg:mb-20"
    >
      <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-slate-100 rounded-full mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-[#B8950A] shrink-0"></span>
        <span class="text-[#B8950A] text-xs font-semibold tracking-[0.2em] uppercase">Choose Your System</span>
      </span>
      <h2 class="font-bold text-4xl lg:text-5xl text-slate-900 leading-tight mb-4">
        Start where you are.
      </h2>
      <p class="font-serif text-2xl italic text-slate-400 mb-4">Scale as you grow.</p>
      <p class="text-slate-500 text-base">Save 30% when you subscribe — and never run out of what your skin needs.</p>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5 lg:gap-4 items-start">
      {offers.map(({ name, tagline, price, priceTo, savingsPrice, description, includes, cta, href, featured }, i) => (
        <div
          x-data
          x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
          class="opacity-0 translate-y-8 transition-all duration-700"
          style={`transition-delay: ${i * 100}ms`}
        >
          <div class={`relative rounded-2xl p-8 lg:p-10 h-full flex flex-col ${
            featured
              ? 'bg-slate-900 text-white shadow-strong lg:scale-105 lg:-translate-y-2'
              : 'bg-white border border-slate-200 shadow-card'
          }`}>

            {featured && (
              <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
                <span class="px-5 py-1.5 bg-[#B8950A] text-white text-xs tracking-[0.15em] uppercase font-bold rounded-full whitespace-nowrap">
                  Most Popular
                </span>
              </div>
            )}

            <!-- Name + tagline -->
            <div class={`mb-6 pb-6 border-b ${featured ? 'border-white/10' : 'border-slate-100'}`}>
              <p class={`text-xs tracking-[0.2em] uppercase font-semibold mb-2 ${featured ? 'text-[#C9A84C]' : 'text-[#B8950A]'}`}>
                {tagline}
              </p>
              <h3 class={`font-bold text-xl ${featured ? 'text-white' : 'text-slate-900'}`}>
                {name}
              </h3>
            </div>

            <!-- Price -->
            <div class="mb-5">
              <div class="flex items-baseline gap-1.5 mb-1">
                <span class={`font-bold text-4xl ${featured ? 'text-white' : 'text-slate-900'}`}>{price}</span>
                <span class={`text-sm font-medium ${featured ? 'text-white/50' : 'text-slate-400'}`}>– {priceTo}</span>
              </div>
              <p class={`text-sm ${featured ? 'text-white/45' : 'text-slate-400'}`}>
                {savingsPrice} with Subscribe & Save 30%
              </p>
            </div>

            <!-- Description -->
            <p class={`text-sm leading-relaxed mb-7 ${featured ? 'text-white/65' : 'text-slate-500'}`}>
              {description}
            </p>

            <!-- Includes -->
            <ul class="space-y-2.5 mb-8 flex-1">
              {includes.map(item => (
                <li class={`flex items-start gap-3 text-sm ${featured ? 'text-white/75' : 'text-slate-600'}`}>
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full shrink-0 bg-[#C9A84C]"></span>
                  {item}
                </li>
              ))}
            </ul>

            <!-- CTA -->
            <a
              href={href}
              target="_blank"
              rel="noopener"
              class={`block text-center py-3.5 text-sm font-semibold rounded-full transition-all duration-200 ${
                featured
                  ? 'bg-[#B8950A] text-white hover:bg-[#9A7D08]'
                  : 'border border-slate-200 text-slate-700 hover:border-[#B8950A] hover:text-[#B8950A]'
              }`}
            >
              {cta}
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
