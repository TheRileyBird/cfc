---
const offers = [
  {
    name: 'Starter System',
    tagline: 'Begin here.',
    price: '$130',
    priceTo: '150',
    savingsPrice: '$110–$130',
    description: 'One cleanser, one treatment, one SPF. The foundation of the CFC protocol — clinically designed, simple to use, results within weeks.',
    includes: [
      'Age Defying Brightening Cleanser',
      'Apple Stem Wrinkle Eraser',
      'Pure Sun Defense SPF 50+',
    ],
    cta: 'Start Your Skin Journey',
    href: 'https://www.cfcskincare.shop/collections/all',
    featured: false,
  },
  {
    name: 'Complete Treatment System',
    tagline: 'The full transformation.',
    price: '$250',
    priceTo: '300',
    savingsPrice: '$175–$210',
    description: 'The full Cleanse-Treat-Protect protocol. Five products, three steps — this is the system our clients use when they stop wearing foundation.',
    includes: [
      'Brightening Glyco Glow Cleanser',
      'Apple Stem Wrinkle Eraser',
      'Color Correction C&E Serum',
      'Pure Hydration Hyaluronic Acid Serum',
      'Sun Kissed Tinted SPF 30',
    ],
    cta: 'Shop the Complete System',
    href: 'https://www.cfcskincare.shop/collections/all',
    featured: true,
  },
  {
    name: 'Premium Collection',
    tagline: 'For women who are serious.',
    price: '$450',
    priceTo: '600+',
    savingsPrice: '$315–$420',
    description: 'The complete system plus advanced NAD+ formulations and the Quad Glow Elite LED Mask. At-home results that rival in-office treatments.',
    includes: [
      'Complete System — all 5 products',
      'NAD+ Age Defying Retinol Cream 0.5%',
      'Revitalizing Retinol Eye Cream',
      'T Tightening and Firming Serum',
      'Quad Glow Elite LED Mask',
    ],
    cta: 'Build Your Premium Routine',
    href: 'https://www.cfcskincare.shop/collections/all',
    featured: false,
  },
];
---

<section class="bg-[#FAF7F2]" id="offers">
  <div class="max-w-7xl mx-auto px-6 lg:px-16 py-24 lg:py-32">

    <!-- Header -->
    <div
      x-data
      x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
      class="opacity-0 translate-y-4 transition-all duration-700 text-center max-w-xl mx-auto mb-16 lg:mb-20"
    >
      <span class="block w-px h-10 bg-[#C9A84C] mx-auto mb-6"></span>
      <p class="text-[#B8950A] text-[0.7rem] tracking-[0.25em] uppercase font-medium mb-4">Choose Your System</p>
      <h2 class="font-serif text-[clamp(2rem,4vw,3rem)] font-light text-charcoal-800 leading-tight mb-4">
        Start where you are.<br/>
        <em class="italic text-[#B8950A]">Scale as you grow.</em>
      </h2>
      <p class="text-charcoal-400 text-sm">Save 30% when you subscribe — and never run out of what your skin needs.</p>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-5 items-start">
      {offers.map(({ name, tagline, price, priceTo, savingsPrice, description, includes, cta, href, featured }, i) => (
        <div
          x-data
          x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
          class="opacity-0 translate-y-8 transition-all duration-700"
          style={`transition-delay: ${i * 100}ms`}
        >
          <div class={`relative rounded-2xl p-8 lg:p-10 h-full flex flex-col ${
            featured
              ? 'bg-charcoal-800 text-white shadow-[0_8px_48px_rgba(0,0,0,0.18)] lg:scale-105 lg:-translate-y-2'
              : 'bg-white border border-[#E8E0D5]'
          }`}>

            {featured && (
              <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
                <span class="px-5 py-1 bg-[#C9A84C] text-white text-[0.65rem] tracking-[0.15em] uppercase font-medium rounded-full">
                  Most Popular
                </span>
              </div>
            )}

            <!-- Name + tagline -->
            <div class="mb-6 pb-6" style={`border-bottom: 1px solid ${featured ? 'rgba(255,255,255,0.1)' : '#E8E0D5'}`}>
              <p class={`text-[0.65rem] tracking-[0.2em] uppercase font-medium mb-2 ${featured ? 'text-[#C9A84C]' : 'text-[#B8950A]'}`}>
                {tagline}
              </p>
              <h3 class={`font-serif text-2xl font-light ${featured ? 'text-white' : 'text-charcoal-800'}`}>
                {name}
              </h3>
            </div>

            <!-- Price -->
            <div class="mb-5">
              <div class="flex items-baseline gap-1.5 mb-1">
                <span class={`font-serif text-4xl font-light ${featured ? 'text-white' : 'text-charcoal-800'}`}>{price}</span>
                <span class={`text-sm ${featured ? 'text-white/60' : 'text-charcoal-400'}`}>– {priceTo}</span>
              </div>
              <p class={`text-xs ${featured ? 'text-white/50' : 'text-charcoal-400'}`}>
                {savingsPrice} with Subscribe & Save 30%
              </p>
            </div>

            <!-- Description -->
            <p class={`text-sm leading-relaxed mb-7 ${featured ? 'text-white/70' : 'text-charcoal-500'}`}>
              {description}
            </p>

            <!-- Includes -->
            <ul class="space-y-2.5 mb-8 flex-1">
              {includes.map(item => (
                <li class={`flex items-start gap-3 text-sm ${featured ? 'text-white/80' : 'text-charcoal-600'}`}>
                  <span class={`mt-1.5 w-1 h-1 rounded-full shrink-0 ${featured ? 'bg-[#C9A84C]' : 'bg-[#C9A84C]'}`}></span>
                  {item}
                </li>
              ))}
            </ul>

            <!-- CTA -->
            <a
              href={href}
              target="_blank"
              rel="noopener"
              class={`block text-center py-3.5 text-[0.7rem] tracking-[0.18em] uppercase font-medium rounded-full transition-all duration-300 ${
                featured
                  ? 'bg-[#C9A84C] text-white hover:bg-[#B8950A]'
                  : 'border border-[#C9A84C] text-[#B8950A] hover:bg-[#C9A84C] hover:text-white'
              }`}
            >
              {cta}
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
