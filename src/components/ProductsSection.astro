---
import { getFeaturedProducts, getProducts } from '../lib/shopify';
import type { ShopifyProduct } from '../lib/shopify';
import ProductCard from './ProductCard.astro';
import { ArrowLeft, ArrowRight } from '@lucide/astro';

export interface Props {
  variant?: 'featured' | 'complete';
  products?: ShopifyProduct[];
  pagination?: {
    currentPage: number;
    totalPages: number;
    totalProducts: number;
  };
}

const { variant = 'featured', products: providedProducts, pagination } = Astro.props;
const isFeatured = variant === 'featured';
const products = providedProducts ?? (isFeatured ? await getFeaturedProducts() : await getProducts(16));
const hasProducts = products.length > 0;

const displayProducts = products;
const filters = ['All', 'Cleanse', 'Treat', 'Protect'];
const heading = isFeatured ? 'Featured\ncollection.' : 'The complete system.';
const ctaHref = isFeatured ? '/shop' : 'https://www.cfcskincare.shop/collections/all';
const ctaLabel = isFeatured ? 'Shop Complete System' : 'View All Products';
const ctaTarget = isFeatured ? undefined : '_blank';

function getProductStep(product: ShopifyProduct): 'cleanse' | 'treat' | 'protect' {
  const text = [
    product.title,
    ...product.tags,
    ...product.collections.edges.map(({ node }) => node.title),
  ].join(' ').toLowerCase();

  if (text.includes('cleanser') || text.includes('cleanse')) return 'cleanse';
  if (text.includes('spf') || text.includes('sunscreen') || text.includes('sun protection')) return 'protect';
  return 'treat';
}

function getShopPageHref(page: number): string {
  return page === 1 ? '/shop' : `/shop/page/${page}`;
}

const productState = displayProducts.map((product, index) => {
  const rankedProduct = product as ShopifyProduct & { bestSellingRank?: number };
  const bestSellingRank = typeof rankedProduct.bestSellingRank === 'number'
    ? rankedProduct.bestSellingRank
    : index;

  return {
    id: product.id,
    title: product.title,
    category: getProductStep(product),
    available: product.availableForSale,
    price: Number(product.priceRange.minVariantPrice.amount),
    bestSellingRank,
  };
});

const initialPage = pagination?.currentPage ?? 1;
const totalProductsLabel = pagination?.totalProducts ?? displayProducts.length;
const firstVisibleIndex = (initialPage - 1) * 16;
const lastVisibleIndex = firstVisibleIndex + 16;
---

<section
  class="bg-parchment"
  id="products"
  style="padding: 120px 0 100px;"
>
  <div style="max-width: 1440px; margin: 0 auto; padding: 0 40px;">

    <!-- Header -->
    <div
      class="reveal flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-16"
    >
      <div>
        <div class="flex items-center gap-4 mb-5">
          <div class="h-px bg-gold" style="width: 24px;"></div>
          <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">Shop CFC</span>
        </div>
        <h2
          class="font-display font-light text-ink"
          style="font-size: clamp(42px, 4.5vw, 68px); line-height: 1.0; letter-spacing: -0.02em; white-space: pre-line;"
        >
          {heading}
        </h2>
      </div>
      <a
        href={ctaHref}
        target={ctaTarget}
        rel={isFeatured ? undefined : 'noopener'}
        class="link-arrow font-mono text-[10px] tracking-[0.18em] uppercase text-gold shrink-0"
      >
        {ctaLabel}
        <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <!-- Filter tabs + grid (state) -->
    <div
      x-data={`{
        active: 'All',
        sortBy: 'alpha',
        page: ${initialPage},
        perPage: 16,
        products: ${JSON.stringify(productState)},
        reset() {
          this.active = 'All';
          this.sortBy = 'alpha';
          this.page = 1;
        },
        filteredProducts() {
          return this.products.filter((product) => {
            return this.active === 'All' || product.category === this.active.toLowerCase();
          });
        },
        sortedProducts() {
          return [...this.filteredProducts()].sort((a, b) => {
            if (this.sortBy === 'best-selling') return a.bestSellingRank - b.bestSellingRank;
            if (this.sortBy === 'reverse-alpha') return b.title.localeCompare(a.title);
            if (this.sortBy === 'price-low-high') return a.price - b.price || a.title.localeCompare(b.title);
            if (this.sortBy === 'price-high-low') return b.price - a.price || a.title.localeCompare(b.title);
            return a.title.localeCompare(b.title);
          });
        },
        visibleProducts() {
          const currentTotalPages = this.totalPages();
          if (this.page > currentTotalPages) this.page = currentTotalPages;
          const start = (this.page - 1) * this.perPage;
          return this.sortedProducts().slice(start, start + this.perPage);
        },
        visibleIds() {
          return this.visibleProducts().map((product) => product.id);
        },
        productOrder(id) {
          return this.visibleIds().indexOf(id);
        },
        totalPages() {
          return Math.max(1, Math.ceil(this.filteredProducts().length / this.perPage));
        },
        totalResults() {
          return this.filteredProducts().length;
        },
        setPage(nextPage) {
          this.page = Math.min(Math.max(nextPage, 1), this.totalPages());
        }
      }`}
    >
      {/* Filter + sort — only for complete variant */}
      {!isFeatured && (
        <div class="mb-10 flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
          <div class="flex flex-wrap gap-0.5">
            {filters.map(f => (
              <button
                @click={`active = '${f}'; page = 1`}
                :class={`active === '${f}' ? 'bg-ink text-white' : 'bg-white text-ink-soft hover:text-ink border border-rule'`}
                class="px-5 py-2.5 font-mono text-[10px] tracking-[0.15em] uppercase transition-all duration-200"
              >
                {f}
              </button>
            ))}
          </div>

          <div class="flex flex-wrap items-center gap-3">
            <label for="product-sort" class="flex items-center gap-3">
              <span class="font-mono text-[10px] tracking-[0.18em] uppercase text-ink-soft">Sort by</span>
              <span class="relative inline-flex items-center">
                <select
                  id="product-sort"
                  name="sort"
                  x-model="sortBy"
                  @change="page = 1"
                  class="h-10 appearance-none border border-rule bg-white font-mono text-[10px] tracking-[0.1em] text-ink-soft outline-none transition-colors focus:border-gold"
                  style="padding: 0 36px 0 14px;"
                >
                  <option value="alpha">Alphabetical</option>
                  <option value="best-selling">Best-selling</option>
                  <option value="reverse-alpha">Reverse alphabetical</option>
                  <option value="price-low-high">Price, low to high</option>
                  <option value="price-high-low">Price, high to low</option>
                </select>
                <svg
                  class="pointer-events-none absolute right-3 h-3 w-3 text-ink-soft"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.17l3.71-3.94a.75.75 0 1 1 1.08 1.04l-4.25 4.5a.75.75 0 0 1-1.08 0l-4.25-4.5a.75.75 0 0 1 .02-1.06Z" clip-rule="evenodd" />
                </svg>
              </span>
            </label>

            <button
              type="button"
              @click="reset()"
              class="h-10 border border-rule bg-white font-mono text-[10px] tracking-[0.15em] uppercase text-ink-soft transition-colors hover:border-ink hover:text-ink"
              style="padding: 0 18px;"
            >
              Reset
            </button>
          </div>
        </div>
      )}

      {/* Products grid — 2px gap mosaic */}
      {hasProducts ? (
        <>
          {!isFeatured && (
            <div class="flex items-center justify-between gap-4 mb-6 font-mono text-[10px] tracking-[0.1em] uppercase text-ink-soft">
              <p>Page <span x-text="page"></span> of <span x-text="totalPages()"></span></p>
              <p><span x-text="totalResults()"></span> of {totalProductsLabel} products</p>
            </div>
          )}

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4" style="gap: 2px;">
            {displayProducts.map((product, i) => {
              const isInitiallyVisible = i >= firstVisibleIndex && i < lastVisibleIndex;
              return (
                <div
                  x-show={`visibleIds().includes(${JSON.stringify(product.id)})`}
                  x-transition:enter="transition ease-out duration-200"
                  x-transition:enter-start="opacity-0 scale-95"
                  x-transition:enter-end="opacity-100 scale-100"
                  class="transition-all duration-200"
                  style={isInitiallyVisible ? undefined : 'display: none;'}
                  :style={`'order: ' + productOrder(${JSON.stringify(product.id)})`}
                >
                  <ProductCard product={product} />
                </div>
              );
            })}
          </div>

          <p x-show="totalResults() === 0" class="mt-8 text-center font-sans font-light text-[14px] text-ink-soft">
            No products match the selected filters.
          </p>

          {!isFeatured && (
            <nav x-show="totalPages() > 1" class="mt-12 flex flex-wrap items-center justify-center gap-1" aria-label="Product pagination">
              <a
                href={getShopPageHref(Math.max(initialPage - 1, 1))}
                @click.prevent="setPage(page - 1)"
                x-show="page > 1"
                class="inline-flex h-10 items-center gap-2 border border-rule bg-white px-4 font-mono text-[10px] tracking-[0.1em] uppercase text-ink-soft transition-colors hover:border-ink hover:text-ink"
              >
                <ArrowLeft class="w-3.5 h-3.5" />
                Prev
              </a>

              <template x-for="pageNumber in totalPages()" :key="pageNumber">
                <a
                  :href="pageNumber === 1 ? '/shop' : `/shop/page/${pageNumber}`"
                  @click.prevent="setPage(pageNumber)"
                  :aria-current="pageNumber === page ? 'page' : undefined"
                  class="inline-flex h-10 min-w-[40px] items-center justify-center px-3 font-mono text-[10px] tracking-[0.1em] uppercase transition-colors"
                  :class="pageNumber === page ? 'bg-ink text-white' : 'border border-rule bg-white text-ink-soft hover:border-ink hover:text-ink'"
                >
                  <span x-text="pageNumber"></span>
                </a>
              </template>

              <a
                href={getShopPageHref(initialPage + 1)}
                @click.prevent="setPage(page + 1)"
                x-show="page < totalPages()"
                class="inline-flex h-10 items-center gap-2 border border-rule bg-white px-4 font-mono text-[10px] tracking-[0.1em] uppercase text-ink-soft transition-colors hover:border-ink hover:text-ink"
              >
                Next
                <ArrowRight class="w-3.5 h-3.5" />
              </a>
            </nav>
          )}

          {pagination && pagination.totalPages > 1 && (
            <noscript>
              <nav class="mt-12 flex flex-wrap items-center justify-center gap-1" aria-label="Product pagination">
                {pagination.currentPage > 1 && (
                  <a
                    href={getShopPageHref(pagination.currentPage - 1)}
                    class="inline-flex h-10 items-center gap-2 border border-rule bg-white px-4 font-mono text-[10px] tracking-[0.1em] uppercase text-ink-soft"
                  >
                    Previous
                  </a>
                )}

                {Array.from({ length: pagination.totalPages }, (_, index) => index + 1).map(page => (
                  <a
                    href={getShopPageHref(page)}
                    aria-current={page === pagination.currentPage ? 'page' : undefined}
                    class={`inline-flex h-10 min-w-[40px] items-center justify-center px-3 font-mono text-[10px] tracking-[0.1em] uppercase ${
                      page === pagination.currentPage
                        ? 'bg-ink text-white'
                        : 'border border-rule bg-white text-ink-soft'
                    }`}
                  >
                    {page}
                  </a>
                ))}

                {pagination.currentPage < pagination.totalPages && (
                  <a
                    href={getShopPageHref(pagination.currentPage + 1)}
                    class="inline-flex h-10 items-center gap-2 border border-rule bg-white px-4 font-mono text-[10px] tracking-[0.1em] uppercase text-ink-soft"
                  >
                    Next
                  </a>
                )}
              </nav>
            </noscript>
          )}
        </>
      ) : (
        <p class="font-sans font-light text-[14px] text-ink-soft">
          Products are temporarily unavailable.
        </p>
      )}
    </div>
  </div>
</section>
