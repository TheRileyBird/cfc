---
import { Instagram, Facebook } from '@lucide/astro';

const links = {
  Shop: [
    { label: 'All Products', href: 'https://www.cfcskincare.shop/collections/all' },
    { label: 'Cleansers', href: 'https://www.cfcskincare.shop/collections/cleanse' },
    { label: 'Treatments', href: 'https://www.cfcskincare.shop/collections/treat' },
    { label: 'Sun Protection', href: 'https://www.cfcskincare.shop/collections/protect' },
  ],
  Learn: [
    { label: 'The System', href: '#system' },
    { label: 'About CFC', href: '#about' },
    { label: 'Our Story', href: '#about' },
    { label: 'Consultation', href: '#contact' },
  ],
  Support: [
    { label: 'Contact Us', href: '#contact' },
    { label: 'FAQs', href: 'https://www.cfcskincare.shop' },
    { label: 'Shipping & Returns', href: 'https://www.cfcskincare.shop' },
    { label: 'Subscribe & Save', href: 'https://www.cfcskincare.shop' },
  ],
};
---

<footer class="bg-charcoal-900 text-charcoal-300">
  <!-- Main footer -->
  <div class="max-w-7xl mx-auto px-6 lg:px-8 pt-16 pb-10">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 mb-12">

      <!-- Brand column -->
      <div class="lg:col-span-2">
        <span class="font-serif text-xl font-semibold text-white">
          CFC <span class="text-gold-400">Skincare</span>
        </span>
        <p class="mt-4 text-sm leading-relaxed max-w-xs">
          Medical-grade, plant-based skincare created by a nurse practitioner.
          Clean. Gentle. Clinically effective — for adults, teens, and tweens.
        </p>
        <p class="mt-3 text-xs text-charcoal-400 italic">
          "Confident Skin That Grows With You."
        </p>
        <div class="flex gap-3 mt-6">
          <a href="https://www.instagram.com/cfcskincare" target="_blank" rel="noopener" aria-label="Instagram"
            class="w-9 h-9 rounded-full bg-charcoal-700 hover:bg-gold-500 flex items-center justify-center transition-colors">
            <Instagram class="w-4 h-4 text-white" />
          </a>
          <a href="https://www.facebook.com/cfcskincare" target="_blank" rel="noopener" aria-label="Facebook"
            class="w-9 h-9 rounded-full bg-charcoal-700 hover:bg-gold-500 flex items-center justify-center transition-colors">
            <Facebook class="w-4 h-4 text-white" />
          </a>
        </div>
      </div>

      <!-- Link columns -->
      {Object.entries(links).map(([group, items]) => (
        <div>
          <h4 class="text-white text-sm font-semibold uppercase tracking-widest mb-4">{group}</h4>
          <ul class="space-y-3">
            {items.map(({ label, href }) => (
              <li>
                <a href={href} class="text-sm hover:text-gold-400 transition-colors">{label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-charcoal-700 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-charcoal-500">
      <p>© {new Date().getFullYear()} CFC Skincare. All rights reserved. Louisiana-made.</p>
      <div class="flex gap-6">
        <a href="https://www.cfcskincare.shop/policies/privacy-policy" class="hover:text-charcoal-300 transition-colors">Privacy Policy</a>
        <a href="https://www.cfcskincare.shop/policies/terms-of-service" class="hover:text-charcoal-300 transition-colors">Terms</a>
        <a href="https://www.cfcskincare.shop/policies/refund-policy" class="hover:text-charcoal-300 transition-colors">Returns</a>
      </div>
    </div>
  </div>
</footer>
