---
import cfcLogo from '../assets/images/cfc-logo.png';

const links = {
  Shop: [
    { label: 'All Products', href: '/shop' },
    { label: 'Cleansers', href: '/shop' },
    { label: 'Treatments', href: '/shop' },
    { label: 'Sun Protection', href: '/shop' },
  ],
  Learn: [
    { label: 'The System', href: '/#system' },
    { label: 'About CFC', href: '/#about' },
    { label: 'Consultation', href: '/#contact' },
  ],
  Support: [
    { label: 'Contact Us', href: '/#contact' },
    { label: 'Subscribe & Save', href: 'https://www.cfcskincare.shop' },
    { label: 'Shipping & Returns', href: 'https://www.cfcskincare.shop' },
  ],
};
---

<footer class="bg-ink" style="padding: 80px 0 32px;">
  <div style="max-width: 1440px; margin: 0 auto; padding: 0 40px;">

    <div class="grid grid-cols-2 lg:grid-cols-5 gap-10 mb-14">

      <!-- Brand -->
      <div class="col-span-2">
        <a href="/" class="mb-6 inline-flex items-center gap-3">
          <img src={cfcLogo.src} alt="CFC Skincare" class="h-10 w-10 rounded-full object-cover shrink-0" />
          <span class="font-mono text-[11px] tracking-[0.22em] uppercase" style="color: rgba(255,255,255,0.7);">CFC Skincare</span>
        </a>
        <p class="font-display italic font-light mb-6" style="font-size: 15px; color: rgba(255,255,255,0.3); max-width: 280px; line-height: 1.5;">
          "Confident Skin That Grows With You."
        </p>
        <div class="flex gap-3">
          {[
            { label: 'IG', href: 'https://www.instagram.com/cfcskincare' },
            { label: 'FB', href: 'https://www.facebook.com/cfcskincare' },
          ].map(({ label, href }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener"
              class="flex items-center justify-center font-mono text-[9px] tracking-widest uppercase transition-all duration-200"
              style="width: 36px; height: 36px; border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.45);"
              onmouseover="this.style.borderColor='oklch(64% 0.115 72)'; this.style.color='oklch(64% 0.115 72)'"
              onmouseout="this.style.borderColor='rgba(255,255,255,0.1)'; this.style.color='rgba(255,255,255,0.45)'"
            >
              {label}
            </a>
          ))}
        </div>
      </div>

      <!-- Links -->
      {Object.entries(links).map(([group, items]) => (
        <div>
          <h4 class="font-mono text-[9px] tracking-[0.2em] uppercase mb-5" style="color: rgba(255,255,255,0.3);">{group}</h4>
          <ul class="space-y-3">
            {items.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  class="font-sans font-light text-[13px] transition-colors duration-200"
                  style="color: rgba(255,255,255,0.45);"
                  onmouseover="this.style.color='oklch(80% 0.08 78)'"
                  onmouseout="this.style.color='rgba(255,255,255,0.45)'"
                >{label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div
      class="flex flex-col sm:flex-row items-center justify-between gap-4"
      style="border-top: 1px solid rgba(255,255,255,0.06); padding-top: 32px;"
    >
      <p class="font-mono text-[9px] tracking-[0.15em] uppercase" style="color: rgba(255,255,255,0.2);">
        © {new Date().getFullYear()} CFC Skincare · Locally made in Louisiana
      </p>
      <div class="flex gap-6">
        {[
          ['Privacy', 'https://www.cfcskincare.shop/policies/privacy-policy'],
          ['Terms', 'https://www.cfcskincare.shop/policies/terms-of-service'],
          ['Returns', 'https://www.cfcskincare.shop/policies/refund-policy'],
        ].map(([label, href]) => (
          <a
            href={href}
            class="font-mono text-[9px] tracking-[0.15em] uppercase transition-colors duration-200"
            style="color: rgba(255,255,255,0.2);"
            onmouseover="this.style.color='rgba(255,255,255,0.45)'"
            onmouseout="this.style.color='rgba(255,255,255,0.2)'"
          >{label}</a>
        ))}
      </div>
    </div>

  </div>
</footer>
