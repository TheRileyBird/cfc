---
import cfcLogo from '../assets/images/cfc-logo.png';

const links = {
  Shop: [
    { label: 'All Products', href: 'https://www.cfcskincare.shop/collections/all' },
    { label: 'Cleansers', href: 'https://www.cfcskincare.shop/collections/all' },
    { label: 'Treatments', href: 'https://www.cfcskincare.shop/collections/all' },
    { label: 'Sun Protection', href: 'https://www.cfcskincare.shop/collections/all' },
  ],
  Learn: [
    { label: 'The System', href: '#system' },
    { label: 'About CFC', href: '#about' },
    { label: 'Consultation', href: '#contact' },
  ],
  Support: [
    { label: 'Contact Us', href: '#contact' },
    { label: 'Subscribe & Save', href: 'https://www.cfcskincare.shop' },
    { label: 'Shipping & Returns', href: 'https://www.cfcskincare.shop' },
  ],
};
---

<footer class="bg-slate-900 text-slate-400">
  <div class="max-w-7xl mx-auto px-6 lg:px-16 pt-16 lg:pt-20 pb-10">

    <div class="grid grid-cols-2 lg:grid-cols-5 gap-10 mb-14">

      <!-- Brand -->
      <div class="col-span-2">
        <a href="/" class="mb-6 inline-flex items-center gap-3">
          <img src={cfcLogo.src} alt="CFC Skincare" class="h-10 w-10 rounded-full object-cover shrink-0" />
          <span class="text-[11px] font-bold tracking-[0.28em] uppercase text-white">CFC Skincare</span>
        </a>
        <p class="text-sm leading-relaxed max-w-xs text-slate-400 mb-2">
          Medical-grade, plant-based skincare created by a nurse practitioner.
          Clean. Gentle. Clinically effective.
        </p>
        <p class="text-sm text-slate-500 font-serif italic mb-6">"Confident Skin That Grows With You."</p>
        <div class="flex gap-3">
          {[
            { label: 'IG', href: 'https://www.instagram.com/cfcskincare' },
            { label: 'FB', href: 'https://www.facebook.com/cfcskincare' },
          ].map(({ label, href }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener"
              class="w-9 h-9 rounded-full border border-slate-700 hover:border-[#C9A84C] hover:text-[#C9A84C] flex items-center justify-center text-xs tracking-widest uppercase font-semibold transition-all duration-200"
            >
              {label}
            </a>
          ))}
        </div>
      </div>

      <!-- Links -->
      {Object.entries(links).map(([group, items]) => (
        <div>
          <h4 class="text-white text-xs tracking-[0.2em] uppercase font-bold mb-5">{group}</h4>
          <ul class="space-y-3">
            {items.map(({ label, href }) => (
              <li>
                <a href={href} class="text-sm hover:text-[#C9A84C] transition-colors duration-200">{label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom -->
    <div class="border-t border-slate-800 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-slate-600">
      <p>© {new Date().getFullYear()} CFC Skincare · Locally made in Louisiana</p>
      <div class="flex gap-6">
        <a href="https://www.cfcskincare.shop/policies/privacy-policy" class="hover:text-slate-400 transition-colors">Privacy</a>
        <a href="https://www.cfcskincare.shop/policies/terms-of-service" class="hover:text-slate-400 transition-colors">Terms</a>
        <a href="https://www.cfcskincare.shop/policies/refund-policy" class="hover:text-slate-400 transition-colors">Returns</a>
      </div>
    </div>

  </div>
</footer>
