---
const problems = [
  {
    number: '01',
    title: 'Made by Marketing, Not Medicine',
    body: 'Most skincare is formulated by chemists hired by marketing departments — not medical professionals. The result sounds impressive on a label but underdelivers on real skin.',
  },
  {
    number: '02',
    title: 'Overwhelming Complexity',
    body: 'Twelve-step routines, conflicting advice, hundreds of competing brands. Women start strong and give up within weeks because the noise is impossible to navigate.',
  },
  {
    number: '03',
    title: 'The Clean vs. Effective False Choice',
    body: 'You\'ve been told natural means weak and medical-grade means harsh — and forced to choose between ingredients you trust and results you need. CFC eliminates this false choice entirely.',
  },
  {
    number: '04',
    title: 'Ignored by the Industry You\'re Funding',
    body: 'Products designed for 25-year-olds don\'t address hormonal shifts, sun damage accumulation, or the specific changes of your 40s and 50s. You\'ve been chronically underserved.',
  },
];
---

<section class="bg-[#FDFCF8]" id="problem">
  <div class="max-w-7xl mx-auto px-6 lg:px-16 py-24 lg:py-32">

    <div class="grid lg:grid-cols-12 gap-12 lg:gap-20">

      <!-- Left: sticky header -->
      <div
        x-data
        x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
        class="opacity-0 translate-y-4 transition-all duration-700 lg:col-span-4 lg:sticky lg:top-32 lg:self-start"
      >
        <span class="block w-px h-10 bg-[#C9A84C] mb-6"></span>
        <p class="text-[#B8950A] text-sm tracking-[0.25em] uppercase font-medium mb-5">The Problem</p>
        <h2 class="font-serif text-[clamp(2rem,3vw,2.75rem)] font-light text-charcoal-800 leading-tight mb-7">
          You haven't found<br/>the right skincare.<br/>
          <em class="italic text-charcoal-400">The industry hasn't<br/>built it — until now.</em>
        </h2>
        <p class="text-charcoal-400 text-base leading-relaxed">
          Women in their 30s, 40s, 50s, and beyond are being failed at every turn. Here is why nothing has worked.
        </p>
      </div>

      <!-- Right: numbered list -->
      <div class="lg:col-span-8 space-y-0">
        {problems.map(({ number, title, body }, i) => (
          <div
            x-data
            x-intersect.once="$el.classList.add('opacity-100', 'translate-x-0')"
            class="opacity-0 translate-x-4 transition-all duration-700 flex gap-8 py-10 border-b border-[#E8E0D5] last:border-0 group hover:pl-2 transition-all"
            style={`transition-delay: ${i * 80}ms`}
          >
            <span class="font-serif text-[#C9A84C]/40 text-4xl font-light leading-none mt-1 select-none shrink-0 w-10 group-hover:text-[#C9A84C]/70 transition-colors duration-300">
              {number}
            </span>
            <div>
              <h3 class="font-serif text-xl font-light text-charcoal-800 mb-3 group-hover:text-[#B8950A] transition-colors duration-300">
                {title}
              </h3>
              <p class="text-charcoal-500 leading-relaxed text-base">{body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Emotional close -->
    <div
      x-data
      x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
      class="opacity-0 translate-y-4 transition-all duration-700 mt-20 lg:mt-28 border-t border-[#E8E0D5] pt-14 text-center"
    >
      <p class="font-serif text-[clamp(1.4rem,3vw,2.25rem)] font-light text-charcoal-700 leading-relaxed max-w-3xl mx-auto">
        "This is not a vanity problem. It is a confidence problem — and confidence touches
        <em class="italic text-[#B8950A]">every area of a woman's life.</em>"
      </p>
    </div>

  </div>
</section>
