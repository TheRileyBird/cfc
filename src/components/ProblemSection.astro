---
import { Image } from 'astro:assets';
import leafImg from '../assets/images/leaf.jpg';

const problems = [
  {
    number: '01',
    title: 'Made by Marketing, Not Medicine',
    body: 'Most skincare is formulated by chemists hired by marketing departments — not medical professionals. The result sounds impressive on a label but underdelivers on real skin.',
  },
  {
    number: '02',
    title: 'Overwhelming Complexity',
    body: 'Twelve-step routines, conflicting advice, hundreds of competing brands. Women start strong and give up within weeks because the noise is impossible to navigate.',
  },
  {
    number: '03',
    title: 'The Clean vs. Effective False Choice',
    body: 'You\'ve been told natural means weak and medical-grade means harsh — and forced to choose between ingredients you trust and results you need. CFC eliminates this false choice entirely.',
  },
  {
    number: '04',
    title: 'Ignored by the Industry You\'re Funding',
    body: 'Products designed for 25-year-olds don\'t always address hormonal shifts, sun damage accumulation, or the specific changes of your 40s and 50s. You\'ve been chronically underserved.',
  },
];
---

<section class="bg-white relative" id="problem" style="padding: 140px 0;">
  <div class="max-w-[1440px] mx-auto px-10">
    <div class="grid grid-cols-1 lg:grid-cols-[5fr_7fr] gap-16 lg:gap-24">

      <!-- Left: sticky -->
      <div class="reveal-left lg:sticky lg:self-start top-[100px]">
        <div class="flex items-center gap-4 mb-7">
          <div class="h-px bg-gold w-6"></div>
          <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">The Problem</span>
        </div>

        <h2 class="bg-white/50 font-display font-light text-ink mb-6 leading-[1.05] tracking-[-0.01em]" style="font-size: clamp(36px, 3.5vw, 52px);">
          You haven't found the right skincare.
        </h2>

        <p class="bg-white/50 font-display text-[22px] italic font-light text-ink-soft leading-relaxed mb-6">
          The industry hasn't built it — until now.
        </p>

        <p class="bg-white/50 font-sans font-light text-[14px] text-ink-soft leading-[1.7]">
          Women in their 30s, 40s, 50s, and beyond are being failed at every turn. Here is why nothing has worked.
        </p>
      </div>

      <!-- Right: numbered list -->
      <div class="border-t border-rule">
        {problems.map(({ number, title, body }, i) => (
          <div
            class="reveal group border-b border-rule flex flex-col items-center text-center lg:flex-row lg:items-start lg:text-left"
            style={`gap: 20px; padding: 40px 0; transition-delay: ${i * 80}ms;`}
          >
            <span
              class="font-display font-light leading-none select-none text-rule transition-colors duration-300 group-hover:text-gold text-[60px] shrink-0 lg:w-16 lg:mt-[2px]"
            >
              {number}
            </span>
            <div>
              <h3 class="font-display text-[24px] font-normal text-ink mb-3 transition-colors duration-300 group-hover:text-gold">
                {title}
              </h3>
              <p class="font-sans font-light text-[14px] text-ink-soft leading-[1.7]">{body}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Ghost leaf — fades in as section scrolls into view -->
      <div
        x-data="{ op: 0.15 }"
        x-init="
          const section = $el.closest('section');
          const update = () => {
            const rect = section.getBoundingClientRect();
            const vh = window.innerHeight;
            const start = vh;
            const end = -(section.offsetHeight / 2);
            const progress = Math.max(0, Math.min(1, (start - rect.top) / (start - end)));
            op = 0.15 - progress * 0.14;
          };
          window.addEventListener('scroll', update, { passive: true });
          update();
        "
        :style="`opacity: ${op}`"
        class="hidden lg:block pointer-events-none select-none absolute left-0 bottom-0"
        style="transition: opacity 0.15s ease;"
        aria-hidden="true"
      >
        <Image
          src={leafImg}
          alt=""
          class="w-96 h-auto"
        />
      </div>
    </div>
  </div>
</section>
