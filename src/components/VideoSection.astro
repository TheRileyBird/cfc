---
import {Image} from "astro:assets";
import moonImg from '../assets/images/moon.png';
import posterImg from '../assets/images/videoposter.png';
const videoUrl = 'https://www.cfcskincare.shop/cdn/shop/videos/c/vp/28aa11f052cb467888c21cfe22b7f013/28aa11f052cb467888c21cfe22b7f013.HD-1080p-2.5Mbps-67327798.mp4?v=0';
---

<section class="bg-ink py-[120px] relative">
  <div class="max-w-[1024px] mx-auto px-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center relative">

      <!-- Left: copy -->
      <div class="reveal-left">
        <div class="relative z-10">
          <div class="flex items-center gap-4 mb-7">
            <div class="h-px w-6 bg-[rgba(255,255,255,0.12)]"></div>
            <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">How to use the System</span>
          </div>

          <h2
            class="font-display font-light text-white mb-6 leading-none tracking-[-0.02em]"
            style="font-size: clamp(42px, 4.5vw, 68px);"
          >
            Get the <br/>
            <em class="text-gold-light" style="font-style: italic;">CFC Glow.</em>
          </h2>

          <p class="font-sans font-light text-[14px] leading-[1.75] mb-10 max-w-[380px]" style="color: rgba(255,255,255,0.55);">
            Three steps. Five minutes. A simple protocol built around your skin — not a shelf full of products that never quite work together.
          </p>

          <a
            href="/shop"
            class="inline-flex items-center font-mono text-[10px] tracking-[0.2em] uppercase transition-colors duration-200 text-ink"
            style="background: oklch(64% 0.115 72); padding: 14px 32px;"
            onmouseover="this.style.background='oklch(80% 0.08 78)'"
            onmouseout="this.style.background='oklch(64% 0.115 72)'"
          >
            Shop the System
          </a>
        </div>


      </div>
      
      <!-- Ghost moon -->
      <div class="hidden lg:flex pointer-events-none select-none absolute z-0 -left-30 top-0 bottom-0 items-center">
        <Image
          src={moonImg}
          alt="moon graphic"
          width={838}
          height={883}
          class="h-[700px] w-[665px] object-contain opacity-5 z-0"
        />
      </div>

      <!-- Right: portrait video with controls -->
      <div class="reveal-right flex justify-center lg:justify-end">
        <div class="w-full md:max-w-[380px] md:mx-auto lg:mx-0 lg:max-w-[380px]">
          <video
            controls
            playsinline
            preload="metadata"
            poster={posterImg.src}
            class="w-full aspect-[9/16] object-cover block"
          >
            <source src={videoUrl} type="video/mp4" />
          </video>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  video::-webkit-media-controls-panel {
    background: linear-gradient(to top, rgba(0,0,0,0.6), transparent);
  }
</style>
