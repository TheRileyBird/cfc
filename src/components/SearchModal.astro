---
---

<div
  x-data
  x-cloak
  x-show="$store.search.isOpen"
  x-transition:enter="transition ease-out duration-200"
  x-transition:enter-start="opacity-0"
  x-transition:enter-end="opacity-100"
  x-transition:leave="transition ease-in duration-150"
  x-transition:leave-start="opacity-100"
  x-transition:leave-end="opacity-0"
  @keydown.escape.window="$store.search.close()"
  class="fixed inset-0 z-[100] bg-white overflow-y-auto"
  role="dialog"
  aria-label="Search"
>
  <div class="max-w-3xl mx-auto px-6 pt-16 pb-16">
    <!-- Top bar -->
    <div class="flex items-center justify-between mb-10">
      <span class="text-[11px] font-black tracking-[0.25em] uppercase text-slate-300">Search</span>
      <button
        @click="$store.search.close()"
        class="flex items-center gap-2 text-[11px] font-bold tracking-[0.2em] uppercase text-slate-400 hover:text-slate-700 transition-colors"
      >
        Close
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Search input -->
    <div class="relative mb-12">
      <svg
        class="absolute left-0 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-300"
        fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"
      >
        <circle cx="11" cy="11" r="8"/>
        <path stroke-linecap="round" d="m21 21-4.35-4.35"/>
      </svg>
      <input
        type="text"
        placeholder="Search products..."
        x-model="$store.search.query"
        @input.debounce.300ms="$store.search.doSearch()"
        x-effect="if ($store.search.isOpen) $nextTick(() => $el.focus())"
        class="w-full pl-8 text-2xl text-slate-900 placeholder-slate-200 border-0 border-b-2 border-slate-100 focus:border-[#B8950A] pb-4 outline-none bg-transparent transition-colors font-light"
        autocomplete="off"
      />
    </div>

    <!-- Loading -->
    <div x-show="$store.search.isLoading" class="flex justify-center py-12">
      <svg class="animate-spin w-6 h-6 text-[#B8950A]" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
      </svg>
    </div>

    <!-- No results -->
    <div
      x-show="!$store.search.isLoading && $store.search.query.length > 0 && $store.search.results.length === 0"
      class="text-center py-12"
    >
      <p class="text-slate-400 text-sm">No results for &ldquo;<span x-text="$store.search.query" class="font-medium text-slate-600"></span>&rdquo;</p>
    </div>

    <!-- Hint when empty -->
    <div
      x-show="!$store.search.isLoading && $store.search.query.length === 0"
      class="text-center py-12"
    >
      <p class="text-slate-300 text-sm">Start typing to search products&hellip;</p>
    </div>

    <!-- Results grid -->
    <div
      x-show="!$store.search.isLoading && $store.search.results.length > 0"
      class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4"
    >
      <template x-for="product in $store.search.results" :key="product.id">
        <a
          :href="`https://www.cfcskincare.shop/products/${product.handle}`"
          @click="$store.search.close()"
          class="group block bg-white rounded-2xl overflow-hidden border border-slate-100 hover:border-slate-200 hover:shadow-lg transition-all duration-200 hover:-translate-y-0.5"
        >
          <div class="aspect-square bg-slate-50 overflow-hidden">
            <img
              :src="product.imageUrl"
              :alt="product.imageAlt || product.title"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </div>
          <div class="p-3">
            <p
              class="text-xs font-semibold text-slate-900 line-clamp-1 group-hover:text-[#B8950A] transition-colors"
              x-text="product.title"
            ></p>
            <p
              class="text-xs text-slate-400 mt-0.5 font-medium"
              x-text="$store.search.formatPrice(product.price)"
            ></p>
          </div>
        </a>
      </template>
    </div>
  </div>
</div>
