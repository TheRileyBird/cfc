---
import { Image } from 'astro:assets';
import alainaImg from '../assets/images/imgi_27_alaina3.jpg';
import kidImg from '../assets/images/kid.jpg';

const testimonials = [
  {
    quote: "I haven't worn foundation to work in three months. I didn't even notice when it stopped feeling necessary. That's when I knew something had actually changed.",
    name: "Sandra M.",
    detail: "Executive · Age 52",
  },
  {
    quote: "I've tried La Mer, SkinCeuticals, all the clean brands. This is the first time I've seen results I can photograph. My pigmentation is actually fading.",
    name: "Karen T.",
    detail: "Teacher & Mother · Age 48",
  },
  {
    quote: "As a woman of color I've been burned by products not made for my skin. CFC is the first brand where I felt like they were thinking about me when they formulated it.",
    name: "Tasha R.",
    detail: "Attorney · Age 41",
  },
  {
    quote: "My med spa NP told me I needed better at-home care. CFC is what she recommended. Now I'm extending every treatment result — effortlessly.",
    name: "Brenda L.",
    detail: "Entrepreneur · Age 55",
  },
];
---

<section class="bg-ink" id="testimonials" style="padding: 140px 0;">
  <div style="max-width: 1440px; margin: 0 auto; padding: 0 40px;">

    <!-- Header: 2-column -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 mb-16 items-end">
      <div class="reveal-left">
        <div class="flex items-center gap-4 mb-7">
          <div class="h-px" style="width: 24px; background: rgba(255,255,255,0.08);"></div>
          <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">Real Women. Real Skin.</span>
        </div>
        <h2 class="font-display font-light text-white" style="font-size: clamp(42px, 4.5vw, 68px); line-height: 1.0; letter-spacing: -0.02em;">
          The results speak for themselves.
        </h2>
      </div>
      <div class="reveal-right">
        <p class="font-sans font-light text-[14px] leading-[1.7]" style="color: rgba(255,255,255,0.4);">
          Women across the country are experiencing real, photographable results from the CFC protocol. Three steps. Five minutes. A lifetime of confidence.
        </p>
      </div>
    </div>

    <!-- Grid: 3 cols, 6 cells, 2px gap -->
    <!-- Order: text, image, text, image, text, text -->
    <div class="grid grid-cols-1 md:grid-cols-3" style="gap: 2px;">

      <!-- Cell 1: text -->
      <div
        class="reveal flex flex-col"
        style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); padding: 48px 40px; transition-delay: 0ms;"
        onmouseover="this.style.background='rgba(255,255,255,0.055)'"
        onmouseout="this.style.background='rgba(255,255,255,0.03)'"
      >
        <div class="text-gold mb-4" style="font-size: 12px; letter-spacing: 4px;">★★★★★</div>
        <p class="font-display italic font-light flex-1 mb-6" style="font-size: 19px; line-height: 1.5; color: rgba(255,255,255,0.75);">
          "{testimonials[0].quote}"
        </p>
        <div style="border-top: 1px solid rgba(255,255,255,0.08); padding-top: 20px;">
          <p class="font-display text-[16px] font-normal text-white">{testimonials[0].name}</p>
          <p class="font-mono uppercase" style="font-size: 9px; letter-spacing: 0.15em; color: rgba(255,255,255,0.3); margin-top: 4px;">{testimonials[0].detail}</p>
        </div>
      </div>

      <!-- Cell 2: image -->
      <div class="reveal overflow-hidden" style="min-height: 340px; transition-delay: 80ms;">
        <Image
          src={alainaImg}
          alt="Woman applying CFC skincare"
          class="w-full h-full object-cover object-top"
          style="min-height: 340px;"
          widths={[400, 700]}
          sizes="(max-width: 768px) 100vw, 33vw"
        />
      </div>

      <!-- Cell 3: text -->
      <div
        class="reveal flex flex-col"
        style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); padding: 48px 40px; transition-delay: 160ms;"
        onmouseover="this.style.background='rgba(255,255,255,0.055)'"
        onmouseout="this.style.background='rgba(255,255,255,0.03)'"
      >
        <div class="text-gold mb-4" style="font-size: 12px; letter-spacing: 4px;">★★★★★</div>
        <p class="font-display italic font-light flex-1 mb-6" style="font-size: 19px; line-height: 1.5; color: rgba(255,255,255,0.75);">
          "{testimonials[1].quote}"
        </p>
        <div style="border-top: 1px solid rgba(255,255,255,0.08); padding-top: 20px;">
          <p class="font-display text-[16px] font-normal text-white">{testimonials[1].name}</p>
          <p class="font-mono uppercase" style="font-size: 9px; letter-spacing: 0.15em; color: rgba(255,255,255,0.3); margin-top: 4px;">{testimonials[1].detail}</p>
        </div>
      </div>

      <!-- Cell 4: image -->
      <div class="reveal overflow-hidden" style="min-height: 340px; transition-delay: 240ms;">
        <Image
          src={kidImg}
          alt="Young woman with radiant skin"
          class="w-full h-full object-cover object-top"
          style="min-height: 340px;"
          widths={[400, 700]}
          sizes="(max-width: 768px) 100vw, 33vw"
        />
      </div>

      <!-- Cell 5: text -->
      <div
        class="reveal flex flex-col"
        style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); padding: 48px 40px; transition-delay: 320ms;"
        onmouseover="this.style.background='rgba(255,255,255,0.055)'"
        onmouseout="this.style.background='rgba(255,255,255,0.03)'"
      >
        <div class="text-gold mb-4" style="font-size: 12px; letter-spacing: 4px;">★★★★★</div>
        <p class="font-display italic font-light flex-1 mb-6" style="font-size: 19px; line-height: 1.5; color: rgba(255,255,255,0.75);">
          "{testimonials[2].quote}"
        </p>
        <div style="border-top: 1px solid rgba(255,255,255,0.08); padding-top: 20px;">
          <p class="font-display text-[16px] font-normal text-white">{testimonials[2].name}</p>
          <p class="font-mono uppercase" style="font-size: 9px; letter-spacing: 0.15em; color: rgba(255,255,255,0.3); margin-top: 4px;">{testimonials[2].detail}</p>
        </div>
      </div>

      <!-- Cell 6: text -->
      <div
        class="reveal flex flex-col"
        style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); padding: 48px 40px; transition-delay: 400ms;"
        onmouseover="this.style.background='rgba(255,255,255,0.055)'"
        onmouseout="this.style.background='rgba(255,255,255,0.03)'"
      >
        <div class="text-gold mb-4" style="font-size: 12px; letter-spacing: 4px;">★★★★★</div>
        <p class="font-display italic font-light flex-1 mb-6" style="font-size: 19px; line-height: 1.5; color: rgba(255,255,255,0.75);">
          "{testimonials[3].quote}"
        </p>
        <div style="border-top: 1px solid rgba(255,255,255,0.08); padding-top: 20px;">
          <p class="font-display text-[16px] font-normal text-white">{testimonials[3].name}</p>
          <p class="font-mono uppercase" style="font-size: 9px; letter-spacing: 0.15em; color: rgba(255,255,255,0.3); margin-top: 4px;">{testimonials[3].detail}</p>
        </div>
      </div>

    </div>
  </div>
</section>
