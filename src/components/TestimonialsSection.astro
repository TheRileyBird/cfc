---
import { Image } from 'astro:assets';
import womanTreatingImg from '../assets/images/imgi_27_alaina3.jpg';
import familyImg from '../assets/images/imgi_10_IMG_7390_88e8c9d5-dc10-4a01-9401-b56afa617598.jpg';
import kidsImg from '../assets/images/imgi_4_hp_bottom_1.jpg';
import youngWomanImg from '../assets/images/imgi_17_tt-62_069ab971-1f75-4920-aa31-53f436d33e38_large.jpg';

const testimonials = [
  {
    quote: "I haven't worn foundation to work in three months. I didn't even notice when it stopped feeling necessary. That's when I knew something had actually changed.",
    name: "Sandra M.",
    detail: "Executive · Age 52",
  },
  {
    quote: "I've tried La Mer, SkinCeuticals, all the clean brands. This is the first time I've seen results I can photograph. My pigmentation is actually fading.",
    name: "Karen T.",
    detail: "Teacher & Mother · Age 48",
  },
  {
    quote: "As a woman of color I've been burned by products not made for my skin. CFC is the first brand where I felt like they were thinking about me when they formulated it.",
    name: "Tasha R.",
    detail: "Attorney · Age 41",
  },
  {
    quote: "My med spa NP told me I needed better at-home care. CFC is what she recommended. Now I'm extending every treatment result — effortlessly.",
    name: "Brenda L.",
    detail: "Entrepreneur · Age 55",
  },
];
---

<section class="bg-white" id="testimonials">

  <!-- Pull quote header -->
  <div class="max-w-7xl mx-auto px-6 lg:px-16 pt-24 lg:pt-32 pb-16 text-center">
    <div
      x-data
      x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
      class="opacity-0 translate-y-4 transition-all duration-700"
    >
      <span class="block w-px h-10 bg-[#C9A84C] mx-auto mb-6"></span>
      <p class="text-[#B8950A] text-[0.7rem] tracking-[0.25em] uppercase font-medium mb-4">Real Women. Real Skin.</p>
      <h2 class="font-serif text-[clamp(2rem,4vw,3.25rem)] font-light text-charcoal-800 leading-tight max-w-2xl mx-auto">
        The results speak<br/><em class="italic text-[#B8950A]">for themselves.</em>
      </h2>
    </div>
  </div>

  <!-- Testimonial grid + photos interspersed -->
  <div class="max-w-7xl mx-auto px-6 lg:px-16 pb-24 lg:pb-32">

    <!-- Row 1: 2 testimonials + 1 image -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-5">
      {testimonials.slice(0, 2).map(({ quote, name, detail }, i) => (
        <div
          x-data
          x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
          class="opacity-0 translate-y-6 transition-all duration-700 flex flex-col justify-between bg-[#FAF7F2] rounded-2xl p-8"
          style={`transition-delay: ${i * 100}ms`}
        >
          <div>
            <div class="flex gap-0.5 text-[#C9A84C] text-xs mb-5">★★★★★</div>
            <p class="font-serif text-charcoal-700 text-lg leading-relaxed italic mb-6">"{quote}"</p>
          </div>
          <div>
            <p class="text-charcoal-800 text-sm font-semibold">{name}</p>
            <p class="text-charcoal-400 text-xs tracking-wide mt-0.5">{detail}</p>
          </div>
        </div>
      ))}

      <!-- Image tile -->
      <div
        x-data
        x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
        class="opacity-0 translate-y-6 transition-all duration-700 delay-200 rounded-2xl overflow-hidden"
        style="min-height: 320px;"
      >
        <Image
          src={womanTreatingImg}
          alt="Woman applying CFC skincare"
          class="w-full h-full object-cover object-top"
          widths={[400, 700]}
          sizes="(max-width: 768px) 100vw, 33vw"
        />
      </div>
    </div>

    <!-- Row 2: 1 image + 2 testimonials -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-5">

      <!-- Wide image tile -->
      <div
        x-data
        x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
        class="opacity-0 translate-y-6 transition-all duration-700 rounded-2xl overflow-hidden"
        style="min-height: 320px;"
      >
        <Image
          src={youngWomanImg}
          alt="Young woman with CFC serum"
          class="w-full h-full object-cover object-top"
          widths={[400, 700]}
          sizes="(max-width: 768px) 100vw, 33vw"
        />
      </div>

      {testimonials.slice(2, 4).map(({ quote, name, detail }, i) => (
        <div
          x-data
          x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
          class="opacity-0 translate-y-6 transition-all duration-700 flex flex-col justify-between bg-[#FAF7F2] rounded-2xl p-8"
          style={`transition-delay: ${(i + 1) * 100}ms`}
        >
          <div>
            <div class="flex gap-0.5 text-[#C9A84C] text-xs mb-5">★★★★★</div>
            <p class="font-serif text-charcoal-700 text-lg leading-relaxed italic mb-6">"{quote}"</p>
          </div>
          <div>
            <p class="text-charcoal-800 text-sm font-semibold">{name}</p>
            <p class="text-charcoal-400 text-xs tracking-wide mt-0.5">{detail}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Row 3: full-width family/lifestyle image -->
    <div
      x-data
      x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
      class="opacity-0 translate-y-6 transition-all duration-700 grid md:grid-cols-2 gap-5"
    >
      <div class="rounded-2xl overflow-hidden" style="min-height: 340px;">
        <Image
          src={familyImg}
          alt="CFC — skincare for the whole family"
          class="w-full h-full object-cover object-top"
          widths={[500, 900]}
          sizes="(max-width: 768px) 100vw, 50vw"
        />
      </div>
      <div class="rounded-2xl overflow-hidden" style="min-height: 340px;">
        <Image
          src={kidsImg}
          alt="CFC skincare for teens and tweens"
          class="w-full h-full object-cover object-center"
          widths={[500, 900]}
          sizes="(max-width: 768px) 100vw, 50vw"
        />
      </div>
    </div>
  </div>
</section>
