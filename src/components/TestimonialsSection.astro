---
const testimonials = [
  {
    quote: "I haven't worn foundation to work in three months. I didn't even notice when it stopped feeling necessary. That's when I knew something had actually changed.",
    name: "Sandra M.",
    detail: "Executive · Age 52",
  },
  {
    quote: "I've tried La Mer, SkinCeuticals, all the clean brands. This is the first time I've seen results I can photograph. My pigmentation is actually fading.",
    name: "Karen T.",
    detail: "Teacher & Mother · Age 48",
  },
  {
    quote: "As a woman of color I've been burned by products not made for my skin. CFC is the first brand where I felt like they were thinking about me when they formulated it.",
    name: "Tasha R.",
    detail: "Attorney · Age 41",
  },
  {
    quote: "My med spa NP told me I needed better at-home care. CFC is what she recommended. Now I'm extending every treatment result — effortlessly.",
    name: "Brenda L.",
    detail: "Entrepreneur · Age 55",
  },
];
---

<section class="bg-ink py-[140px]" id="testimonials">
  <div class="max-w-[1024px] mx-auto px-10">

    <!-- Header -->
    <div class="reveal text-center mb-16">
      <div class="flex items-center justify-center gap-4 mb-7">
        <div class="h-px w-6 bg-[rgba(255,255,255,0.08)]"></div>
        <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">Real Women. Real Skin.</span>
        <div class="h-px w-6 bg-[rgba(255,255,255,0.08)]"></div>
      </div>
      <h2 class="font-display font-light text-white leading-none tracking-[-0.02em]" style="font-size: clamp(42px, 4.5vw, 68px);">
        The results speak<br/>for themselves.
      </h2>
    </div>

    <!-- Carousel -->
    <div
      x-data="{ active: 0 }"
      class="reveal"
    >
      <!-- Track -->
      <div class="overflow-hidden">
        <div
          class="flex transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]"
          :style="`transform: translateX(-${active * 100}%)`"
        >
          {testimonials.map((t) => (
            <div class="w-full shrink-0 px-1">
              <div
                class="flex flex-col px-8 sm:px-12 py-12 h-full"
                style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05);"
              >
                <div class="text-gold text-[12px] tracking-[4px] mb-6">★★★★★</div>
                <p
                  class="font-display italic font-light flex-1 mb-8 leading-[1.5]"
                  style={`font-size: clamp(18px, 2vw, 24px); color: rgba(255,255,255,0.85);`}
                >
                  "{t.quote}"
                </p>
                <div class="pt-5" style="border-top: 1px solid rgba(255,255,255,0.08);">
                  <p class="font-display text-[17px] font-normal text-white">{t.name}</p>
                  <p class="font-mono text-[9px] tracking-[0.15em] uppercase mt-1" style="color: rgba(255,255,255,0.35);">{t.detail}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Controls -->
      <div class="flex items-center justify-between mt-8">

        <!-- Prev -->
        <button
          @click="active = Math.max(0, active - 1)"
          :disabled="active === 0"
          :class="active === 0 ? 'opacity-25 cursor-not-allowed' : 'hover:border-gold'"
          class="w-10 h-10 flex items-center justify-center border transition-all duration-200"
          style="border-color: rgba(255,255,255,0.2); color: rgba(255,255,255,0.7);"
          aria-label="Previous"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
          </svg>
        </button>

        <!-- Dots -->
        <div class="flex items-center gap-2">
          {testimonials.map((_, i) => (
            <button
              @click={`active = ${i}`}
              :class={`active === ${i} ? 'bg-gold w-5' : 'bg-[rgba(255,255,255,0.2)] w-1.5 hover:bg-[rgba(255,255,255,0.4)]'`}
              class="h-1.5 rounded-full transition-all duration-300"
              aria-label={`Go to testimonial ${i + 1}`}
            ></button>
          ))}
        </div>

        <!-- Next -->
        <button
          @click={`active = Math.min(${testimonials.length - 1}, active + 1)`}
          :disabled={`active === ${testimonials.length - 1}`}
          :class={`active === ${testimonials.length - 1} ? 'opacity-25 cursor-not-allowed' : 'hover:border-gold'`}
          class="w-10 h-10 flex items-center justify-center border transition-all duration-200"
          style="border-color: rgba(255,255,255,0.2); color: rgba(255,255,255,0.7);"
          aria-label="Next"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </button>

      </div>
    </div>

  </div>
</section>
