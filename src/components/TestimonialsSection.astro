---
import { Image } from 'astro:assets';
import womanTreatingImg from '../assets/images/imgi_27_alaina3.jpg';
import familyImg from '../assets/images/imgi_10_IMG_7390_88e8c9d5-dc10-4a01-9401-b56afa617598.jpg';
import kidsImg from '../assets/images/imgi_4_hp_bottom_1.jpg';
import youngWomanImg from '../assets/images/kid.jpg';

const testimonials = [
  {
    quote: "I haven't worn foundation to work in three months. I didn't even notice when it stopped feeling necessary. That's when I knew something had actually changed.",
    name: "Sandra M.",
    detail: "Executive · Age 52",
  },
  {
    quote: "I've tried La Mer, SkinCeuticals, all the clean brands. This is the first time I've seen results I can photograph. My pigmentation is actually fading.",
    name: "Karen T.",
    detail: "Teacher & Mother · Age 48",
  },
  {
    quote: "As a woman of color I've been burned by products not made for my skin. CFC is the first brand where I felt like they were thinking about me when they formulated it.",
    name: "Tasha R.",
    detail: "Attorney · Age 41",
  },
  {
    quote: "My med spa NP told me I needed better at-home care. CFC is what she recommended. Now I'm extending every treatment result — effortlessly.",
    name: "Brenda L.",
    detail: "Entrepreneur · Age 55",
  },
];
---

<section class="bg-white border-t border-slate-100" id="testimonials">

  <!-- Header -->
  <div class="max-w-7xl mx-auto px-6 lg:px-16 pt-24 lg:pt-32 pb-16 text-center">
    <div
      x-data
      x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
      class="opacity-0 translate-y-4 transition-all duration-700"
    >
      <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-slate-100 rounded-full mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-[#B8950A] shrink-0"></span>
        <span class="text-[#B8950A] text-xs font-semibold tracking-[0.2em] uppercase">Real Women. Real Skin.</span>
      </span>
      <h2 class="font-bold text-4xl lg:text-5xl text-slate-900 leading-tight">
        The results speak for themselves.
      </h2>
    </div>
  </div>

  <!-- Grid: testimonials + photos -->
  <div class="max-w-7xl mx-auto px-6 lg:px-16 pb-24 lg:pb-32">

    <!-- Row 1 -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
      {testimonials.slice(0, 2).map(({ quote, name, detail }, i) => (
        <div
          x-data
          x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
          class="opacity-0 translate-y-6 transition-all duration-700 aspect-square flex flex-col justify-between bg-slate-50 rounded-2xl p-7 border border-slate-100 overflow-hidden"
          style={`transition-delay: ${i * 100}ms`}
        >
          <div>
            <div class="flex gap-0.5 text-[#C9A84C] text-sm mb-5">★★★★★</div>
            <p class="font-serif text-slate-700 text-lg leading-relaxed italic mb-6">"{quote}"</p>
          </div>
          <div>
            <p class="text-slate-900 text-sm font-semibold">{name}</p>
            <p class="text-slate-400 text-sm mt-0.5">{detail}</p>
          </div>
        </div>
      ))}

      <!-- Image tile -->
      <div
        x-data
        x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
        class="opacity-0 translate-y-6 transition-all duration-700 delay-200 aspect-square rounded-2xl overflow-hidden"
      >
        <Image
          src={womanTreatingImg}
          alt="Woman applying CFC skincare"
          class="w-full h-full object-cover object-top"
          widths={[400, 700]}
          sizes="(max-width: 768px) 100vw, 33vw"
        />
      </div>
    </div>

    <!-- Row 2 -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
      <div
        x-data
        x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
        class="opacity-0 translate-y-6 transition-all duration-700 aspect-square rounded-2xl overflow-hidden"
      >
        <Image
          src={youngWomanImg}
          alt="Young woman with CFC serum"
          class="w-full h-full object-cover object-top"
          widths={[400, 700]}
          sizes="(max-width: 768px) 100vw, 33vw"
        />
      </div>

      {testimonials.slice(2, 4).map(({ quote, name, detail }, i) => (
        <div
          x-data
          x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
          class="opacity-0 translate-y-6 transition-all duration-700 aspect-square flex flex-col justify-between bg-slate-50 rounded-2xl p-7 border border-slate-100 overflow-hidden"
          style={`transition-delay: ${(i + 1) * 100}ms`}
        >
          <div>
            <div class="flex gap-0.5 text-[#C9A84C] text-sm mb-5">★★★★★</div>
            <p class="font-serif text-slate-700 text-lg leading-relaxed italic mb-6">"{quote}"</p>
          </div>
          <div>
            <p class="text-slate-900 text-sm font-semibold">{name}</p>
            <p class="text-slate-400 text-sm mt-0.5">{detail}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
