---
import { Image } from 'astro:assets';
import cleanseImg from '../assets/images/imgi_13_tt-102_1500x.jpg';
import treatImg from '../assets/images/imgi_27_alaina3.jpg';
import protectImg from '../assets/images/imgi_12_tt-75_1500x.jpg';

const steps = [
  {
    number: '01',
    step: 'Cleanse',
    headline: 'A clean slate, not a stripped one.',
    body: 'Gentle, plant-based cleansers that remove impurities without compromising your skin\'s natural barrier. Options include our Age Defying Brightening, Glyco Glow, NAD+ Bamboo Firming, and Jamin Jasmine formulas.',
    products: ['Age Defying Brightening Cleanser', 'Brightening Glyco Glow Cleanser', 'NAD+ Bamboo Firming Cleanser', 'Jamin Jasmine Cleanser'],
    image: cleanseImg,
    imageAlt: 'Woman cleansing face at sink with CFC products',
    imagePosition: 'right',
  },
  {
    number: '02',
    step: 'Treat',
    headline: 'Where clinical results happen.',
    body: 'The heart of the CFC system. Three hero treatments working in synergy to address pigmentation, oxidative damage, fine lines, and cellular hydration.',
    products: ['Apple Stem Wrinkle Eraser', 'Color Correction C&E Serum', 'Pure Hydration Hyaluronic Acid Serum'],
    image: treatImg,
    imageAlt: 'Woman applying CFC treatment serum',
    imagePosition: 'left',
  },
  {
    number: '03',
    step: 'Protect',
    headline: 'Guard every result you\'ve earned.',
    body: 'Medical-grade SPF formulations that protect your skin investment and wear beautifully on all skin tones — no white cast, no compromise.',
    products: ['Pure Sun Defense SPF 50+', 'Sun Kissed Protection Tinted SPF 30'],
    image: protectImg,
    imageAlt: 'Woman at sink with CFC skincare routine',
    imagePosition: 'right',
  },
];
---

<section class="bg-[#FAF7F2]" id="system">

  <!-- Section header -->
  <div class="max-w-7xl mx-auto px-6 lg:px-16 pt-24 lg:pt-32 pb-16 lg:pb-20 text-center">
    <div
      x-data
      x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
      class="opacity-0 translate-y-4 transition-all duration-700"
    >
      <span class="block w-px h-10 bg-[#C9A84C] mx-auto mb-6"></span>
      <p class="text-[#B8950A] text-sm tracking-[0.25em] uppercase font-medium mb-4">The Solution</p>
      <h2 class="font-serif text-[clamp(2rem,4vw,3.5rem)] font-light text-charcoal-800 leading-tight">
        Three steps. Under five minutes.<br/>
        <em class="italic text-[#B8950A]">Real results.</em>
      </h2>
    </div>
  </div>

  <!-- Steps — full-bleed editorial -->
  {steps.map(({ number, step, headline, body, products, image, imageAlt, imagePosition }, i) => (
    <div
      x-data
      x-intersect.once="$el.classList.add('opacity-100')"
      class="opacity-0 transition-all duration-1000 grid lg:grid-cols-2"
      style={`transition-delay: ${i * 100}ms`}
    >
      <!-- Image -->
      <div class={`relative overflow-hidden ${imagePosition === 'left' ? 'lg:order-first' : 'lg:order-last'} order-first`}>
        <Image
          src={image}
          alt={imageAlt}
          class="w-full h-64 lg:h-full object-cover object-center"
          widths={[600, 900, 1200]}
          sizes="(max-width: 1024px) 100vw, 50vw"
        />
        <!-- Step number watermark -->
        <div class="absolute top-8 left-8 lg:top-12 lg:left-12">
          <span class="font-serif text-[5rem] lg:text-[8rem] font-light leading-none text-white/20 select-none">{number}</span>
        </div>
      </div>

      <!-- Content -->
      <div class={`flex flex-col justify-center px-8 lg:px-16 xl:px-24 py-16 lg:py-24 bg-[#FDFCF8] ${imagePosition === 'left' ? 'lg:order-last' : 'lg:order-first'}`}>
        <div class="max-w-md">
          <div class="flex items-center gap-4 mb-8">
            <span class="w-8 h-px bg-[#C9A84C]"></span>
            <span class="text-[#B8950A] text-sm tracking-[0.25em] uppercase font-medium">{step}</span>
          </div>

          <h3 class="font-serif text-[clamp(1.75rem,3vw,2.5rem)] font-light text-charcoal-800 leading-snug mb-5">
            {headline}
          </h3>
          <p class="text-charcoal-500 leading-relaxed mb-8 text-base">{body}</p>

          <ul class="space-y-3 mb-10">
            {products.map(p => (
              <li class="flex items-center gap-3 text-charcoal-600 text-sm">
                <span class="w-1 h-1 rounded-full bg-[#C9A84C] shrink-0"></span>
                {p}
              </li>
            ))}
          </ul>

          <a
            href="#products"
            class="inline-flex items-center gap-3 text-sm tracking-[0.18em] uppercase font-medium text-[#B8950A] hover:gap-5 transition-all duration-300 group"
          >
            Shop {step}
            <span class="w-8 h-px bg-[#C9A84C] group-hover:w-12 transition-all duration-300"></span>
          </a>
        </div>
      </div>
    </div>
  ))}
</section>
