---
import { Image } from 'astro:assets';
import cleanseImg from '../assets/images/imgi_13_tt-102_1500x.jpg';
import treatImg from '../assets/images/protect.jpg';
import protectImg from '../assets/images/imgi_27_alaina3.jpg';

const steps = [
  {
    number: '01',
    step: 'Cleanse',
    stepLabel: 'Step 01',
    headline: 'A clean slate, not a stripped one.',
    body: 'Gentle, plant-based cleansers that remove impurities without compromising your skin\'s natural barrier. Options include our Age Defying Brightening, Glyco Glow, NAD+ Bamboo Firming, and Jamin Jasmine formulas.',
    products: ['Age Defying Brightening Cleanser', 'Brightening Glyco Glow Cleanser', 'NAD+ Bamboo Firming Cleanser', 'Jamin Jasmine Cleanser'],
    image: cleanseImg,
    imageAlt: 'Woman cleansing face at sink with CFC products',
    imageRight: true,
  },
  {
    number: '02',
    step: 'Treat',
    stepLabel: 'Step 02',
    headline: 'Where clinical results happen.',
    body: 'The heart of the CFC system. Three hero treatments working in synergy to address pigmentation, oxidative damage, fine lines, and cellular hydration.',
    products: ['Apple Stem Wrinkle Eraser', 'Color Correction C&E Serum', 'Pure Hydration Hyaluronic Acid Serum'],
    image: treatImg,
    imageAlt: 'Woman applying CFC treatment serum',
    imageRight: false,
  },
  {
    number: '03',
    step: 'Protect',
    stepLabel: 'Step 03',
    headline: 'Guard every result you\'ve earned.',
    body: 'Medical-grade SPF formulations that protect your skin investment and wear beautifully on all skin tones — no white cast, no compromise.',
    products: ['Pure Sun Defense SPF 50+', 'Sun Kissed Protection Tinted SPF 30'],
    image: protectImg,
    imageAlt: 'Woman at sink with CFC skincare routine',
    imageRight: true,
  },
];
---

<section id="system" class="bg-ink">

  <!-- Section header -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-16 items-end" style="max-width: 1440px; margin: 0 auto; padding: 120px 40px 80px;">
    <div class="reveal-left">
      <div class="flex items-center gap-4 mb-7">
        <div class="h-px" style="width: 24px; background: rgba(255,255,255,0.08);"></div>
        <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">The Solution</span>
      </div>
      <h2 class="font-display font-light text-white" style="font-size: clamp(52px, 5.5vw, 84px); line-height: 1.0; letter-spacing: -0.02em;">
        3 Steps.<br/><em class="not-italic" style="font-style: italic; color: oklch(80% 0.08 78);">5 Minutes.</em>
      </h2>
    </div>
    <div class="reveal-right">
      <p class="font-display italic font-light" style="font-size: 20px; color: rgba(255,255,255,0.5); line-height: 1.5;">
        This is not a vanity problem. It is a confidence problem — and confidence touches every area of a woman's life.
      </p>
    </div>
  </div>

  <!-- Steps -->
  {steps.map(({ number, step, stepLabel, headline, body, products, image, imageAlt, imageRight }, i) => (
    <div
      class="reveal grid grid-cols-1 lg:grid-cols-2 overflow-hidden"
      style={`min-height: 600px; border-top: 1px solid rgba(255,255,255,0.06); transition-delay: ${i * 80}ms;`}
    >

      <!-- Image (alternates sides) -->
      <div
        class="relative overflow-hidden group"
        style={imageRight ? 'order: 2;' : 'order: 1;'}
      >
        <Image
          src={image}
          alt={imageAlt}
          class="w-full h-full object-cover object-top transition-transform duration-[900ms] ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.04]"
          widths={[600, 900, 1200]}
          sizes="50vw"
        />
      </div>

      <!-- Content -->
      <div
        class="relative overflow-hidden flex flex-col justify-center"
        style={`padding: 72px 80px; ${imageRight ? 'order: 1;' : 'order: 2;'}`}
      >
        <!-- Ghost number -->
        <span
          aria-hidden="true"
          class="absolute font-display font-light leading-none select-none pointer-events-none"
          style="font-size: 280px; color: rgba(255,255,255,0.025); right: -20px; bottom: -40px;"
        >{number}</span>

        <div class="relative" style="max-width: 380px;">
          <!-- Step label -->
          <div class="flex items-center gap-4 mb-7">
            <div class="h-px bg-gold" style="width: 20px;"></div>
            <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">{step} — {stepLabel}</span>
          </div>

          <h3 class="font-display font-light text-white mb-5" style="font-size: clamp(32px, 2.8vw, 44px); line-height: 1.1;">
            {headline}
          </h3>

          <p class="font-sans font-light text-[14px] leading-[1.7] mb-8" style="color: rgba(255,255,255,0.45);">
            {body}
          </p>

          <ul class="mb-8 space-y-2">
            {products.map(p => (
              <li class="flex items-center gap-3 font-sans font-light text-[13px]" style="color: rgba(255,255,255,0.5);">
                <span class="h-px bg-gold shrink-0" style="width: 16px;"></span>
                {p}
              </li>
            ))}
          </ul>

          <a href="/shop" class="link-arrow font-mono text-[10px] tracking-[0.18em] uppercase text-gold">
            Shop {step}
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  ))}
</section>
