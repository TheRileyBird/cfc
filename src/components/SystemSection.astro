---
import { Image } from 'astro:assets';
import cleanseImg from '../assets/images/imgi_13_tt-102_1500x.jpg';
import treatImg from '../assets/images/protect.jpg';
import protectImg from '../assets/images/imgi_27_alaina3.jpg';

const steps = [
  {
    number: '01',
    step: 'Cleanse',
    headline: 'A clean slate, not a stripped one.',
    body: 'Gentle, plant-based cleansers that remove impurities without compromising your skin\'s natural barrier. Options include our Age Defying Brightening, Glyco Glow, NAD+ Bamboo Firming, and Jamin Jasmine formulas.',
    products: ['Age Defying Brightening Cleanser', 'Brightening Glyco Glow Cleanser', 'NAD+ Bamboo Firming Cleanser', 'Jamin Jasmine Cleanser'],
    image: cleanseImg,
    imageAlt: 'Woman cleansing face at sink with CFC products',
    imagePosition: 'right' as const,
    bg: 'bg-white',
  },
  {
    number: '02',
    step: 'Treat',
    headline: 'Where clinical results happen.',
    body: 'The heart of the CFC system. Three hero treatments working in synergy to address pigmentation, oxidative damage, fine lines, and cellular hydration.',
    products: ['Apple Stem Wrinkle Eraser', 'Color Correction C&E Serum', 'Pure Hydration Hyaluronic Acid Serum'],
    image: treatImg,
    imageAlt: 'Woman applying CFC treatment serum',
    imagePosition: 'left' as const,
    bg: 'bg-slate-50',
  },
  {
    number: '03',
    step: 'Protect',
    headline: 'Guard every result you\'ve earned.',
    body: 'Medical-grade SPF formulations that protect your skin investment and wear beautifully on all skin tones — no white cast, no compromise.',
    products: ['Pure Sun Defense SPF 50+', 'Sun Kissed Protection Tinted SPF 30'],
    image: protectImg,
    imageAlt: 'Woman at sink with CFC skincare routine',
    imagePosition: 'right' as const,
    bg: 'bg-white',
  },
];
---

<section id="system">

  <!-- Section header -->
  <div class="bg-slate-50 border-y border-slate-100">
    <div class="max-w-4xl mx-auto px-6 lg:px-16 py-16 lg:py-20 text-center">
      <div
        x-data
        x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
        class="opacity-0 translate-y-4 transition-all duration-700"
      >
        <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-white border border-slate-200 rounded-full mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-[#B8950A] shrink-0"></span>
          <span class="text-[#B8950A] text-xs font-semibold tracking-[0.2em] uppercase">The Solution</span>
        </span>
        <h2 class="font-bold text-4xl lg:text-5xl text-slate-900 leading-tight mb-3">
          3 Steps. 5 Minutes.
        </h2>
        <p class="text-2xl text-slate-700">This is not a vanity problem. It is a confidence problem — and confidence touches <span class="text-[#B8950A]"> every area of a woman's life.</span></p>
      </div>
    </div>
  </div>

  <!-- Steps — alternating image/text -->
  {steps.map(({ number, step, headline, body, products, image, imageAlt, imagePosition, bg }, i) => (
    <div
      x-data
      x-intersect.once="$el.classList.add('opacity-100')"
      class={`opacity-0 transition-all duration-1000 grid lg:grid-cols-2 lg:h-[650px] overflow-hidden ${bg}`}
      style={`transition-delay: ${i * 80}ms`}
    >

      <!-- Image -->
      <div class={`relative overflow-hidden ${imagePosition === 'left' ? 'lg:order-first' : 'lg:order-last'} order-first`}>
        <Image
          src={image}
          alt={imageAlt}
          class="w-full h-72 lg:h-full object-cover object-center"
          widths={[600, 900, 1200]}
          sizes="(max-width: 1024px) 100vw, 50vw"
        />
        <!-- Step badge -->
        <div class="absolute top-6 left-6">
          <span class="inline-flex items-center gap-2.5 px-4 py-2 bg-white/95 backdrop-blur-sm rounded-full shadow-card">
            <span class="text-[#B8950A] text-xs font-bold tracking-[0.15em] uppercase">{step}</span>
            <span class="text-slate-300 text-xs">·</span>
            <span class="text-slate-400 text-xs font-medium tabular-nums">{number}</span>
          </span>
        </div>
      </div>

      <!-- Content -->
      <div class={`relative overflow-hidden flex flex-col justify-center px-8 lg:px-16 xl:px-20 py-16 lg:py-24 ${imagePosition === 'left' ? 'lg:order-last' : 'lg:order-first'}`}>
        <!-- Ghosted step number -->
        <span aria-hidden="true" class="absolute -bottom-8 right-0 text-[18rem] font-bold leading-none text-slate-900/[0.04] select-none pointer-events-none tabular-nums">{number}</span>
        <div class="max-w-md relative">
          <h3 class="font-bold text-3xl lg:text-4xl text-slate-900 leading-snug mb-5">
            {headline}
          </h3>
          <p class="text-slate-500 leading-relaxed mb-8 text-base">{body}</p>

          <ul class="space-y-3 mb-10">
            {products.map(p => (
              <li class="flex items-center gap-3 text-slate-600 text-sm">
                <span class="w-1.5 h-1.5 rounded-full bg-[#C9A84C] shrink-0"></span>
                {p}
              </li>
            ))}
          </ul>

          <a
            href="/shop"
            class="inline-flex items-center gap-2 text-sm font-semibold text-[#B8950A] hover:text-[#9A7D08] transition-colors group"
          >
            Shop {step}
            <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  ))}
</section>
