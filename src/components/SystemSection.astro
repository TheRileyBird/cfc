---
import { Image } from 'astro:assets';
import cleanseImg from '../assets/images/imgi_13_tt-102_1500x.jpg';
import treatImg from '../assets/images/imgi_27_alaina3.jpg';
import protectImg from '../assets/images/imgi_12_tt-75_1500x.jpg';

const steps = [
  {
    number: '01',
    step: 'Cleanse',
    headline: 'A clean slate, not a stripped one.',
    body: 'Gentle, plant-based cleansers that remove impurities without compromising your skin\'s natural barrier. Options include our Age Defying Brightening, Glyco Glow, NAD+ Bamboo Firming, and Jamin Jasmine formulas.',
    products: ['Age Defying Brightening Cleanser', 'Brightening Glyco Glow Cleanser', 'NAD+ Bamboo Firming Cleanser', 'Jamin Jasmine Cleanser'],
    image: cleanseImg,
    imageAlt: 'Woman cleansing face at sink with CFC products',
    imagePosition: 'right',
  },
  {
    number: '02',
    step: 'Treat',
    headline: 'Where clinical results happen.',
    body: 'The heart of the CFC system. Three hero treatments working in synergy to address pigmentation, oxidative damage, fine lines, and cellular hydration.',
    products: ['Apple Stem Wrinkle Eraser', 'Color Correction C&E Serum', 'Pure Hydration Hyaluronic Acid Serum'],
    image: treatImg,
    imageAlt: 'Woman applying CFC treatment serum',
    imagePosition: 'left',
  },
  {
    number: '03',
    step: 'Protect',
    headline: 'Guard every result you\'ve earned.',
    body: 'Medical-grade SPF formulations that protect your skin investment and wear beautifully on all skin tones — no white cast, no compromise.',
    products: ['Pure Sun Defense SPF 50+', 'Sun Kissed Protection Tinted SPF 30'],
    image: protectImg,
    imageAlt: 'Woman at sink with CFC skincare routine',
    imagePosition: 'right',
  },
];
---

<section class="bg-[#FAF7F2]" id="system">
  <div class="max-w-7xl mx-auto px-6 lg:px-16 py-24 lg:py-32">
    <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-end mb-14">
      <div
        x-data
        x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
        class="opacity-0 translate-y-4 transition-all duration-700"
      >
        <p class="text-sm tracking-[0.24em] uppercase text-[#9a7d3f] font-medium mb-4">The Routine</p>
        <h2 class="font-serif text-[clamp(2.1rem,4vw,4rem)] leading-[1] text-charcoal-800">
          Simple care,
          <br />
          structured like
          <br />
          <em class="italic text-[#b99649]">a real protocol.</em>
        </h2>
      </div>
      <p
        x-data
        x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
        class="opacity-0 translate-y-4 transition-all duration-700 delay-100 max-w-2xl text-lg leading-relaxed text-charcoal-500"
      >
        Inspired by the cleaner merchandising flow of the reference design, this section turns CFC’s system into three clear choices with supporting imagery, quick product cues, and direct shopping paths.
      </p>
    </div>

    <div class="grid gap-6 lg:grid-cols-3">
      {steps.map(({ number, step, headline, body, products, image, imageAlt }, i) => (
        <article
          x-data
          x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
          class="opacity-0 translate-y-6 transition-all duration-700 overflow-hidden rounded-[2rem] border border-[#eadcc8] bg-[#fffdf8]"
          style={`transition-delay: ${i * 100}ms`}
        >
          <div class="relative">
            <Image
              src={image}
              alt={imageAlt}
              class="h-72 w-full object-cover object-top"
              widths={[500, 800]}
              sizes="(max-width: 1024px) 100vw, 33vw"
            />
            <div class="absolute left-5 top-5 flex items-center gap-3 rounded-full bg-[#fffaf2]/90 px-4 py-2 backdrop-blur-sm">
              <span class="font-serif text-xl text-[#b99649]">{number}</span>
              <span class="text-xs uppercase tracking-[0.22em] text-charcoal-600">{step}</span>
            </div>
          </div>

          <div class="p-7">
            <h3 class="font-serif text-3xl leading-tight text-charcoal-800">{headline}</h3>
            <p class="mt-4 text-base leading-relaxed text-charcoal-500">{body}</p>
            <ul class="mt-6 space-y-2">
              {products.slice(0, 3).map(p => (
                <li class="flex items-center gap-3 text-sm text-charcoal-600">
                  <span class="h-1.5 w-1.5 rounded-full bg-[#b99649]"></span>
                  {p}
                </li>
              ))}
            </ul>
            <a
              href="#products"
              class="mt-7 inline-flex items-center gap-3 text-sm uppercase tracking-[0.18em] text-[#9a7d3f] transition-colors hover:text-charcoal-800"
            >
              Shop {step}
              <span class="block h-px w-8 bg-[#b99649]"></span>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
