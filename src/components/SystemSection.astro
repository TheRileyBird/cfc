---
import { Image } from 'astro:assets';
import cleanseImg from '../assets/images/imgi_13_tt-102_1500x.jpg';
import treatImg from '../assets/images/protect.jpg';
import protectImg from '../assets/images/imgi_27_alaina3.jpg';

const steps = [
  {
    number: '01',
    step: 'Cleanse',
    stepLabel: 'Step 01',
    headline: 'A clean slate, not a stripped one.',
    body: 'Gentle, plant-based cleansers that remove impurities without compromising your skin\'s natural barrier. Options include our Age Defying Brightening, NAD+ Bamboo Firming, and Jamin Jasmine formulas.',
    products: [
      { name: 'Age Defying Brightening Cleanser', href: '/products/age-defying-brightening-cleanser' },
      { name: 'NAD+ Bamboo Firming Cleanser', href: '/products/nad-bamboo-firming-cleanser' },
      { name: 'Jamin Jasmine Cleanser', href: '/products/jamin-jasmine-nad-cleanser' },
    ],
    image: cleanseImg,
    imageAlt: 'Woman cleansing face at sink with CFC products',
    imageRight: true,
  },
  {
    number: '02',
    step: 'Treat',
    stepLabel: 'Step 02',
    headline: 'Where clinical results happen.',
    body: 'The heart of the CFC system. Three hero treatments working in synergy to address pigmentation, oxidative damage, fine lines, and cellular hydration.',
    products: [
      { name: 'Apple Stem Wrinkle Eraser', href: '/products/apple-stem-wrinkle-eraser' },
      { name: 'Color Correction C&E Serum', href: '/products/color-correction-c-e-serum' },
      { name: 'Pure Hydration Hyaluronic Acid Serum', href: '/products/pure-hydration-ha' },
    ],
    image: treatImg,
    imageAlt: 'Woman applying CFC treatment serum',
    imageRight: false,
  },
  {
    number: '03',
    step: 'Protect',
    stepLabel: 'Step 03',
    headline: 'Guard every result you\'ve earned.',
    body: 'Medical-grade SPF formulations that protect your skin investment and wear beautifully on all skin tones — no white cast, no compromise.',
    products: [
      { name: 'Pure Sun Defense SPF 50+', href: '/products/pure-sun-defense-sunscreen' },
      { name: 'Sun Kissed Protection Tinted SPF 30', href: '/products/sun-kissed-protection-sunscreen' },
    ],
    image: protectImg,
    imageAlt: 'Woman at sink with CFC skincare routine',
    imageRight: true,
  },
];
---

<section id="system" class="bg-ink">

  <!-- Steps -->
  {steps.map(({ number, step, stepLabel, headline, body, products, image, imageAlt, imageRight }, i) => (
    <div
      class="reveal grid grid-cols-1 lg:grid-cols-2 lg:h-[650px] overflow-hidden"
      style={`border-top: 1px solid rgba(255,255,255,0.06); transition-delay: ${i * 80}ms;`}
    >

      <!-- Image (alternates sides) -->
      <div
        class={`relative overflow-hidden group h-[300px] lg:h-auto ${imageRight ? 'order-2' : 'order-2 lg:order-1'}`}
      >
        <Image
          src={image}
          alt={imageAlt}
          class="w-full h-full object-cover object-center transition-transform duration-[900ms] ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.04]"
          widths={[600, 900, 1200]}
          sizes="50vw"
        />
      </div>

      <!-- Content -->
      <div
        class={`relative overflow-hidden flex flex-col justify-center px-8 py-12 lg:px-20 lg:py-[72px] ${imageRight ? 'order-1' : 'order-1 lg:order-2'}`}
      >
        <!-- Ghost number -->
        <span
          aria-hidden="true"
          class="absolute font-display font-light leading-none select-none pointer-events-none text-[rgba(255,255,255,0.06)]"
          style="font-size: 360px; right: -30px; bottom: -60px;"
        >{number}</span>

        <div class="relative max-w-[380px]">
          <!-- Step label -->
          <div class="flex items-center gap-4 mb-7">
            <div class="h-px bg-gold w-5"></div>
            <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">{step} — {stepLabel}</span>
          </div>

          <h3 class="font-display font-light text-white mb-5 leading-[1.1]" style="font-size: clamp(32px, 2.8vw, 44px);">
            {headline}
          </h3>

          <p class="font-sans font-light text-[14px] leading-[1.7] mb-8 text-[rgba(255,255,255,0.55)]">
            {body}
          </p>

          <ul class="mb-8 space-y-2">
            {products.map(p => (
              <li class="flex items-center gap-3 font-sans font-light text-[13px] text-[rgba(255,255,255,0.6)]">
                <span class="h-px bg-gold shrink-0 w-4"></span>
                <a href={p.href} class="transition-colors duration-200 hover:text-gold">
                  {p.name}
                </a>
              </li>
            ))}
          </ul>

          <a href="/shop" class="link-arrow font-mono text-[10px] tracking-[0.18em] uppercase text-gold">
            Shop {step}
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  ))}
</section>
