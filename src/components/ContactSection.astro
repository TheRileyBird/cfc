---
import founderImg from '../assets/images/brit.jpg';
import { Image } from 'astro:assets';
---

<section class="bg-parchment" id="contact" style="padding: 140px 0;">
  <div style="max-width: 1440px; margin: 0 auto; padding: 0 40px;">
    <div class="grid grid-cols-1 lg:grid-cols-[5fr_7fr] gap-16 lg:gap-24 items-start">

      <!-- Left: content -->
      <div class="reveal-left">
        <div class="flex items-center gap-4 mb-7">
          <div class="h-px bg-gold" style="width: 24px;"></div>
          <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">Get In Touch</span>
        </div>

        <h2 class="font-display font-light text-ink mb-5" style="font-size: clamp(36px, 3.5vw, 52px); line-height: 1.05; letter-spacing: -0.01em;">
          Your skin deserves a personal conversation.
        </h2>

        <p class="font-sans font-light text-[14px] text-ink-soft leading-[1.7] mb-8" style="max-width: 400px;">
          The CFC founder — a nurse practitioner — is available for consultation. Tell us about your skin and we'll help you find the right protocol.
        </p>

        <!-- Founder note -->
        <div
          class="bg-white grid gap-5 mb-8 items-start"
          style="padding: 28px; border: 1px solid oklch(88% 0.006 72); grid-template-columns: 64px 1fr;"
        >
          <Image
            src={founderImg}
            alt="CFC Founder NP"
            class="object-cover object-top shrink-0"
            style="width: 64px; height: 64px;"
            widths={[128]}
            sizes="64px"
          />
          <div>
            <p class="font-display text-[17px] font-normal text-ink mb-1.5">Direct access to the NP who built it</p>
            <p class="font-sans font-light text-[13px] text-ink-soft leading-relaxed">
              No chatbot. No corporate inbox. A medical professional who will actually read your message and respond.
            </p>
          </div>
        </div>

        <!-- Trust stats: 3 columns -->
        <div class="grid grid-cols-3" style="border: 1px solid oklch(88% 0.006 72);">
          {[
            ['24h', 'Response time'],
            ['100%', 'Confidential'],
            ['Free', 'Consultation'],
          ].map(([stat, label], i) => (
            <div
              class="text-center"
              style={`padding: 20px; ${i < 2 ? 'border-right: 1px solid oklch(88% 0.006 72);' : ''}`}
            >
              <p class="font-display text-[30px] font-light text-ink leading-none mb-2">{stat}</p>
              <p class="font-mono text-ink-soft uppercase" style="font-size: 9px; letter-spacing: 0.15em;">{label}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: form -->
      <div class="reveal-right">
        <form
          name="consultation"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          x-data="{ submitted: false }"
          @submit.prevent="
            fetch('/', {
              method: 'POST',
              headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
              body: new URLSearchParams(new FormData($el)).toString()
            }).then(() => { submitted = true });
          "
          class="bg-white"
          style="border: 1px solid oklch(88% 0.006 72); padding: 56px;"
        >
          <input type="hidden" name="form-name" value="consultation" />
          <p class="hidden">
            <label>Don't fill this out: <input name="bot-field" /></label>
          </p>

          <!-- Success state -->
          <div x-show="submitted" class="text-center py-8">
            <div class="w-16 h-16 bg-parchment flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h3 class="font-display text-[24px] font-normal text-ink mb-2">Message received.</h3>
            <p class="font-sans font-light text-[14px] text-ink-soft">We'll be in touch within 24 hours.</p>
          </div>

          <!-- Form fields -->
          <div x-show="!submitted" class="space-y-5">
            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label class="block font-mono text-[9px] tracking-[0.2em] uppercase text-ink-soft mb-2">First Name</label>
                <input
                  type="text"
                  name="first_name"
                  required
                  class="w-full font-sans text-[14px] text-ink bg-parchment border border-rule transition-colors duration-200 focus:outline-none focus:border-gold"
                  style="padding: 14px 16px;"
                  placeholder="Sandra"
                />
              </div>
              <div>
                <label class="block font-mono text-[9px] tracking-[0.2em] uppercase text-ink-soft mb-2">Last Name</label>
                <input
                  type="text"
                  name="last_name"
                  required
                  class="w-full font-sans text-[14px] text-ink bg-parchment border border-rule transition-colors duration-200 focus:outline-none focus:border-gold"
                  style="padding: 14px 16px;"
                  placeholder="Mitchell"
                />
              </div>
            </div>

            <div>
              <label class="block font-mono text-[9px] tracking-[0.2em] uppercase text-ink-soft mb-2">Email</label>
              <input
                type="email"
                name="email"
                required
                class="w-full font-sans text-[14px] text-ink bg-parchment border border-rule transition-colors duration-200 focus:outline-none focus:border-gold"
                style="padding: 14px 16px;"
                placeholder="sandra@example.com"
              />
            </div>

            <div>
              <label class="block font-mono text-[9px] tracking-[0.2em] uppercase text-ink-soft mb-2">Primary Skin Concern</label>
              <select
                name="concern"
                class="w-full font-sans text-[14px] text-ink bg-parchment border border-rule transition-colors duration-200 focus:outline-none focus:border-gold appearance-none"
                style="padding: 14px 16px;"
              >
                <option value="">Select a concern...</option>
                <option>Pigmentation / Dark Spots</option>
                <option>Fine Lines & Wrinkles</option>
                <option>Dryness & Dehydration</option>
                <option>Rosacea / Redness</option>
                <option>Uneven Skin Tone</option>
                <option>Sagging / Loss of Firmness</option>
                <option>General Anti-Aging</option>
                <option>Not Sure — Need Guidance</option>
              </select>
            </div>

            <div>
              <label class="block font-mono text-[9px] tracking-[0.2em] uppercase text-ink-soft mb-2">Tell Us About Your Skin</label>
              <textarea
                name="message"
                rows="4"
                class="w-full font-sans text-[14px] text-ink bg-parchment border border-rule transition-colors duration-200 focus:outline-none focus:border-gold resize-none"
                style="padding: 14px 16px;"
                placeholder="What have you tried? What's working? What isn't?"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full bg-ink text-white font-mono text-[11px] tracking-[0.2em] uppercase transition-colors duration-200 hover:bg-gold-deep"
              style="padding: 18px;"
            >
              Request a Consultation
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
