---
const faqs = [
  {
    question: 'What skin types work well with CFC?',
    answer: 'The collection is designed to be approachable for dry, combination, mature, and sensitive-leaning skin, with formulas organized around support, brightness, and daily protection.',
  },
  {
    question: 'How do I choose the right starting routine?',
    answer: 'Start with one cleanser, one treatment, and one SPF. That structure mirrors the CFC system and keeps the routine easy to sustain while you learn what your skin responds to best.',
  },
  {
    question: 'Are the formulas plant-based and results-driven?',
    answer: 'Yes. The line is framed around plant-based formulation choices, but the positioning stays clinical: the goal is visible improvement, not ingredient theater.',
  },
];
---
<section class="py-24 lg:py-32 bg-[#FAF7F2]" id="contact">
  <div class="max-w-7xl mx-auto px-6 lg:px-16">
    <div class="grid lg:grid-cols-[1.1fr_0.9fr] gap-16 items-start">
      <div
        x-data
        x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
        class="opacity-0 translate-y-6 transition-all duration-700"
      >
        <p class="text-gold-500 text-sm font-medium tracking-[0.24em] uppercase mb-4">FAQs</p>
        <h2 class="font-serif text-[clamp(2rem,4vw,3.5rem)] leading-tight text-charcoal-800 mb-6">
          Your answers to
          <span class="italic text-gold-500"> popular questions.</span>
        </h2>
        <p class="text-charcoal-500 leading-relaxed mb-10 max-w-2xl text-lg">
          The reference design closes with practical reassurance. This version does the same, then offers a direct consultation form for anyone who wants help choosing a routine.
        </p>

        <div class="space-y-4">
          {faqs.map(({ question, answer }, index) => (
            <div class="rounded-[2rem] border border-[#e4d8c8] bg-[#fffdf8] p-6">
              <div class="flex items-start justify-between gap-4">
                <h3 class="font-serif text-2xl leading-tight text-charcoal-800">{question}</h3>
                <span class="text-sm text-gold-500 uppercase tracking-[0.18em]">0{index + 1}</span>
              </div>
              <p class="mt-4 text-charcoal-500 leading-relaxed">{answer}</p>
            </div>
          ))}
        </div>
      </div>

      <div
        x-data
        x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
        class="opacity-0 translate-y-6 transition-all duration-700 delay-100"
      >
        <form
          name="consultation"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          x-data="{ submitted: false }"
          @submit.prevent="
            fetch('/', {
              method: 'POST',
              headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
              body: new URLSearchParams(new FormData($el)).toString()
            }).then(() => { submitted = true });
          "
          class="bg-[#fffdf8] rounded-[2rem] border border-[#e4d8c8] p-8 space-y-5 shadow-elegant"
        >
          <input type="hidden" name="form-name" value="consultation" />
          <p class="hidden">
            <label>Don't fill this out: <input name="bot-field" /></label>
          </p>

          <!-- Success state -->
          <div x-show="submitted" class="text-center py-8">
            <div class="w-16 h-16 bg-sage-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-sage-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h3 class="font-serif text-xl font-semibold text-charcoal-800 mb-2">Message received.</h3>
            <p class="text-charcoal-500">We'll be in touch within 24 hours.</p>
          </div>

          <div x-show="!submitted" class="space-y-5">
            <div>
              <p class="text-sm uppercase tracking-[0.24em] text-gold-500 mb-2">Consultation</p>
              <h3 class="font-serif text-3xl leading-tight text-charcoal-800">Need help building your routine?</h3>
              <p class="mt-3 text-charcoal-500 leading-relaxed">
                Send a note and we’ll help point you toward the right cleanser, treatment, and protection combination.
              </p>
            </div>
            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-medium text-charcoal-600 mb-1.5 uppercase tracking-wide">First Name</label>
                <input
                  type="text"
                  name="first_name"
                  required
                  class="w-full px-4 py-3 bg-white border border-cream-300 rounded-xl text-charcoal-800 placeholder-charcoal-300 text-base focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent transition-all"
                  placeholder="Sandra"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-charcoal-600 mb-1.5 uppercase tracking-wide">Last Name</label>
                <input
                  type="text"
                  name="last_name"
                  required
                  class="w-full px-4 py-3 bg-white border border-cream-300 rounded-xl text-charcoal-800 placeholder-charcoal-300 text-base focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent transition-all"
                  placeholder="Mitchell"
                />
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-charcoal-600 mb-1.5 uppercase tracking-wide">Email</label>
              <input
                type="email"
                name="email"
                required
                class="w-full px-4 py-3 bg-white border border-cream-300 rounded-xl text-charcoal-800 placeholder-charcoal-300 text-base focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent transition-all"
                placeholder="sandra@example.com"
              />
            </div>

            <div>
              <label class="block text-sm font-medium text-charcoal-600 mb-1.5 uppercase tracking-wide">My Primary Skin Concern</label>
              <select
                name="concern"
                class="w-full px-4 py-3 bg-white border border-cream-300 rounded-xl text-charcoal-800 text-base focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent transition-all"
              >
                <option value="">Select a concern...</option>
                <option>Pigmentation / Dark Spots</option>
                <option>Fine Lines & Wrinkles</option>
                <option>Dryness & Dehydration</option>
                <option>Rosacea / Redness</option>
                <option>Uneven Skin Tone</option>
                <option>Sagging / Loss of Firmness</option>
                <option>General Anti-Aging</option>
                <option>Not Sure — Need Guidance</option>
              </select>
            </div>

            <div>
              <label class="block text-sm font-medium text-charcoal-600 mb-1.5 uppercase tracking-wide">Tell Us About Your Skin</label>
              <textarea
                name="message"
                rows="4"
                class="w-full px-4 py-3 bg-white border border-cream-300 rounded-xl text-charcoal-800 placeholder-charcoal-300 text-base focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent transition-all resize-none"
                placeholder="What have you tried? What's working? What isn't?"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full py-4 bg-charcoal-800 hover:bg-gold-600 text-white font-medium rounded-full transition-all duration-200 shadow-card hover:shadow-elegant"
            >
              Request a Consultation
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
