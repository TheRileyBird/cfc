---
---
<section class="py-24 lg:py-32 bg-white" id="contact">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-start">

      <!-- Left: content -->
      <div
        x-data
        x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
        class="opacity-0 translate-y-6 transition-all duration-700"
      >
        <div class="flex items-center gap-3 mb-4">
          <span class="w-8 h-px bg-gold-500"></span>
          <span class="text-gold-500 text-sm font-medium tracking-widest uppercase">Get In Touch</span>
        </div>
        <h2 class="font-serif text-3xl lg:text-4xl font-semibold text-charcoal-800 leading-tight mb-6">
          Your skin deserves<br/>
          <span class="text-gold-500">a personal conversation.</span>
        </h2>
        <p class="text-charcoal-500 leading-relaxed mb-8 max-w-md">
          The CFC founder — a nurse practitioner — is available for consultation. Tell us about your skin and we'll help you find the right protocol.
        </p>

        <!-- Founder note -->
        <div class="flex gap-4 p-5 bg-cream-100 rounded-2xl border-l-4 border-gold-400">
          <img
            src="https://images.unsplash.com/photo-1559839734-2b71ea197ec2?w=56&h=56&q=80&fit=crop&crop=face"
            alt="CFC Founder NP"
            class="w-14 h-14 rounded-xl object-cover shrink-0"
          />
          <div>
            <p class="font-semibold text-charcoal-800 text-sm mb-1">Direct access to the NP who built it</p>
            <p class="text-charcoal-500 text-sm leading-relaxed">
              No chatbot. No corporate inbox. A medical professional who will actually read your message and respond.
            </p>
          </div>
        </div>
      </div>

      <!-- Right: Netlify form -->
      <div
        x-data
        x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
        class="opacity-0 translate-y-6 transition-all duration-700 delay-100"
      >
        <form
          name="consultation"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          x-data="{ submitted: false }"
          @submit.prevent="
            fetch('/', {
              method: 'POST',
              headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
              body: new URLSearchParams(new FormData($el)).toString()
            }).then(() => { submitted = true });
          "
          class="bg-cream-100 rounded-3xl p-8 space-y-5 shadow-elegant"
        >
          <input type="hidden" name="form-name" value="consultation" />
          <p class="hidden">
            <label>Don't fill this out: <input name="bot-field" /></label>
          </p>

          <!-- Success state -->
          <div x-show="submitted" class="text-center py-8">
            <div class="w-16 h-16 bg-sage-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-sage-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h3 class="font-serif text-xl font-semibold text-charcoal-800 mb-2">Message received.</h3>
            <p class="text-charcoal-500">We'll be in touch within 24 hours.</p>
          </div>

          <!-- Form fields -->
          <div x-show="!submitted" class="space-y-5">
            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-xs font-medium text-charcoal-600 mb-1.5 uppercase tracking-wide">First Name</label>
                <input
                  type="text"
                  name="first_name"
                  required
                  class="w-full px-4 py-3 bg-white border border-cream-300 rounded-xl text-charcoal-800 placeholder-charcoal-300 text-sm focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent transition-all"
                  placeholder="Sandra"
                />
              </div>
              <div>
                <label class="block text-xs font-medium text-charcoal-600 mb-1.5 uppercase tracking-wide">Last Name</label>
                <input
                  type="text"
                  name="last_name"
                  required
                  class="w-full px-4 py-3 bg-white border border-cream-300 rounded-xl text-charcoal-800 placeholder-charcoal-300 text-sm focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent transition-all"
                  placeholder="Mitchell"
                />
              </div>
            </div>

            <div>
              <label class="block text-xs font-medium text-charcoal-600 mb-1.5 uppercase tracking-wide">Email</label>
              <input
                type="email"
                name="email"
                required
                class="w-full px-4 py-3 bg-white border border-cream-300 rounded-xl text-charcoal-800 placeholder-charcoal-300 text-sm focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent transition-all"
                placeholder="sandra@example.com"
              />
            </div>

            <div>
              <label class="block text-xs font-medium text-charcoal-600 mb-1.5 uppercase tracking-wide">My Primary Skin Concern</label>
              <select
                name="concern"
                class="w-full px-4 py-3 bg-white border border-cream-300 rounded-xl text-charcoal-800 text-sm focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent transition-all"
              >
                <option value="">Select a concern...</option>
                <option>Pigmentation / Dark Spots</option>
                <option>Fine Lines & Wrinkles</option>
                <option>Dryness & Dehydration</option>
                <option>Rosacea / Redness</option>
                <option>Uneven Skin Tone</option>
                <option>Sagging / Loss of Firmness</option>
                <option>General Anti-Aging</option>
                <option>Not Sure — Need Guidance</option>
              </select>
            </div>

            <div>
              <label class="block text-xs font-medium text-charcoal-600 mb-1.5 uppercase tracking-wide">Tell Us About Your Skin</label>
              <textarea
                name="message"
                rows="4"
                class="w-full px-4 py-3 bg-white border border-cream-300 rounded-xl text-charcoal-800 placeholder-charcoal-300 text-sm focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent transition-all resize-none"
                placeholder="What have you tried? What's working? What isn't?"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full py-4 bg-gold-500 hover:bg-gold-600 text-white font-medium rounded-full transition-all duration-200 shadow-card hover:shadow-elegant"
            >
              Request a Consultation
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
