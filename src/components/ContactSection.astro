---
import founderImg from '../assets/images/brit.jpg';
import {Image} from "astro:assets";
---
<section class="py-24 lg:py-32 bg-slate-50 border-t border-slate-100" id="contact">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-start">

      <!-- Left: content -->
      <div
        x-data
        x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
        class="opacity-0 translate-y-6 transition-all duration-700"
      >
        <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-white border border-slate-200 rounded-full mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-[#B8950A] shrink-0"></span>
          <span class="text-[#B8950A] text-xs font-semibold tracking-[0.2em] uppercase">Get In Touch</span>
        </span>
        <h2 class="font-bold text-3xl lg:text-4xl text-slate-900 leading-tight mb-5">
          Your skin deserves a personal conversation.
        </h2>
        <p class="text-slate-500 leading-relaxed mb-8 max-w-md text-base">
          The CFC founder — a nurse practitioner — is available for consultation. Tell us about your skin and we'll help you find the right protocol.
        </p>

        <!-- Founder note -->
        <div class="flex gap-4 p-5 bg-white rounded-2xl border border-slate-200 shadow-card">
          <Image
              src={founderImg}
              alt="CFC Founder NP"
              class="w-14 h-14 rounded-xl object-cover shrink-0"
          />
          <div>
            <p class="font-semibold text-slate-900 text-sm mb-1.5">Direct access to the NP who built it</p>
            <p class="text-slate-500 text-sm leading-relaxed">
              No chatbot. No corporate inbox. A medical professional who will actually read your message and respond.
            </p>
          </div>
        </div>

        <!-- Trust signals -->
        <div class="mt-8 grid grid-cols-3 gap-4">
          {[
            ['24h', 'Response time'],
            ['100%', 'Confidential'],
            ['Free', 'Consultation'],
          ].map(([stat, label]) => (
            <div class="text-center p-4 bg-white rounded-xl border border-slate-200 shadow-card">
              <p class="font-bold text-2xl text-slate-900 mb-0.5">{stat}</p>
              <p class="text-slate-400 text-xs font-medium">{label}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: form -->
      <div
        x-data
        x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
        class="opacity-0 translate-y-6 transition-all duration-700 delay-100"
      >
        <form
          name="consultation"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          x-data="{ submitted: false }"
          @submit.prevent="
            fetch('/', {
              method: 'POST',
              headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
              body: new URLSearchParams(new FormData($el)).toString()
            }).then(() => { submitted = true });
          "
          class="bg-white rounded-2xl p-8 space-y-5 shadow-lift border border-slate-100"
        >
          <input type="hidden" name="form-name" value="consultation" />
          <p class="hidden">
            <label>Don't fill this out: <input name="bot-field" /></label>
          </p>

          <!-- Success state -->
          <div x-show="submitted" class="text-center py-8">
            <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-[#B8950A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h3 class="font-bold text-xl text-slate-900 mb-2">Message received.</h3>
            <p class="text-slate-500">We'll be in touch within 24 hours.</p>
          </div>

          <!-- Form fields -->
          <div x-show="!submitted" class="space-y-5">
            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-xs font-semibold text-slate-600 mb-1.5 uppercase tracking-widest">First Name</label>
                <input
                  type="text"
                  name="first_name"
                  required
                  class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-slate-900 placeholder-slate-300 text-sm focus:outline-none focus:ring-2 focus:ring-[#B8950A]/30 focus:border-[#B8950A] transition-all"
                  placeholder="Sandra"
                />
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-600 mb-1.5 uppercase tracking-widest">Last Name</label>
                <input
                  type="text"
                  name="last_name"
                  required
                  class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-slate-900 placeholder-slate-300 text-sm focus:outline-none focus:ring-2 focus:ring-[#B8950A]/30 focus:border-[#B8950A] transition-all"
                  placeholder="Mitchell"
                />
              </div>
            </div>

            <div>
              <label class="block text-xs font-semibold text-slate-600 mb-1.5 uppercase tracking-widest">Email</label>
              <input
                type="email"
                name="email"
                required
                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-slate-900 placeholder-slate-300 text-sm focus:outline-none focus:ring-2 focus:ring-[#B8950A]/30 focus:border-[#B8950A] transition-all"
                placeholder="sandra@example.com"
              />
            </div>

            <div>
              <label class="block text-xs font-semibold text-slate-600 mb-1.5 uppercase tracking-widest">Primary Skin Concern</label>
              <select
                name="concern"
                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-slate-900 text-sm focus:outline-none focus:ring-2 focus:ring-[#B8950A]/30 focus:border-[#B8950A] transition-all"
              >
                <option value="">Select a concern...</option>
                <option>Pigmentation / Dark Spots</option>
                <option>Fine Lines & Wrinkles</option>
                <option>Dryness & Dehydration</option>
                <option>Rosacea / Redness</option>
                <option>Uneven Skin Tone</option>
                <option>Sagging / Loss of Firmness</option>
                <option>General Anti-Aging</option>
                <option>Not Sure — Need Guidance</option>
              </select>
            </div>

            <div>
              <label class="block text-xs font-semibold text-slate-600 mb-1.5 uppercase tracking-widest">Tell Us About Your Skin</label>
              <textarea
                name="message"
                rows="4"
                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-slate-900 placeholder-slate-300 text-sm focus:outline-none focus:ring-2 focus:ring-[#B8950A]/30 focus:border-[#B8950A] transition-all resize-none"
                placeholder="What have you tried? What's working? What isn't?"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full py-4 bg-[#B8950A] hover:bg-[#9A7D08] text-white font-semibold text-sm rounded-full transition-all duration-200"
            >
              Request a Consultation
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
