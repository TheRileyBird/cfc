---
import { getSystemBuilderData, getSystemPriceRange } from '../lib/system-builder';

const data = await getSystemBuilderData();
const wizardData = JSON.stringify(data);
---

<section
  class="bg-parchment min-h-screen"
  style="padding: 128px 0 100px;"
  x-data={`systemWizard(${wizardData})`}
  x-init="
    const params = new URLSearchParams(window.location.search);
    const requested = params.get('system');
    if (systems.some((system) => system.id === requested)) selectedSystem = requested;
  "
>
  <div class="max-w-5xl mx-auto px-6 sm:px-10">
    <div class="text-center mx-auto mb-12 max-w-[640px]">
      <div class="flex items-center justify-center gap-4 mb-4">
        <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">The System Builder</span>
      </div>
      <h1 class="font-display font-light text-ink mb-4 leading-none" style="font-size: clamp(42px, 5vw, 72px);">
        Craft your care.
      </h1>
      <!--<p class="font-sans font-light text-[14px] leading-relaxed text-ink-soft">-->
      <!--  Select one system to get started. Then choose your cleanser and SPF; everything else marked included is automatically added.-->
      <!--</p>-->
    </div>

    <div class="bg-white">
        <div class="p-6 sm:p-8 lg:p-10 border-b border-rule">
          <div class="flex items-center justify-between gap-6 mb-6">
            <div>
              <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">Start Here</span>
              <h2 class="font-display text-[32px] leading-tight text-ink mt-2">Select your system.</h2>
            </div>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
            <template x-for="system in systems" :key="system.id">
              <button
                type="button"
                @click="selectedSystem = system.id"
                class="text-left p-6 border transition-all duration-200"
                :class="selectedSystem === system.id ? 'bg-ink text-white border-ink shadow-strong' : 'bg-white text-ink border-rule hover:border-gold'"
              >
                <span class="font-mono text-[9px] tracking-[0.18em] uppercase text-gold" x-text="system.eyebrow"></span>
                <span class="block font-display text-[25px] leading-tight mt-3" x-text="system.name"></span>
                <span
                  class="block font-sans font-light text-[12px] leading-relaxed mt-3"
                  :class="selectedSystem === system.id ? 'text-[rgba(255,255,255,0.62)]' : 'text-ink-soft'"
                  x-text="system.description"
                ></span>
                <span
                  class="block font-mono text-[10px] tracking-[0.1em] mt-4"
                  :class="selectedSystem === system.id ? 'text-gold' : 'text-ink-soft'"
                  x-text="systemPriceRange(system)"
                ></span>
                <span
                  class="inline-flex mt-5 font-mono text-[9px] tracking-[0.16em] uppercase"
                  :class="selectedSystem === system.id ? 'text-gold' : 'text-ink-soft'"
                >
                  <span x-show="selectedSystem === system.id">Selected</span>
                  <span x-show="selectedSystem !== system.id">Select</span>
                </span>
              </button>
            </template>
          </div>
        </div>

        <div class="p-6 sm:p-8 lg:p-10 border-b border-rule">
          <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-3 mb-6">
            <div>
              <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">Step 01</span>
              <h2 class="font-display text-[32px] leading-tight text-ink mt-2">Choose your cleanser.</h2>
            </div>
          </div>
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 pt-4">
            <template x-for="cleanser in products.cleansers" :key="cleanser.variantId || cleanser.handle">
              <button
                type="button"
                @click="selectedCleanser = cleanser.variantId"
                class="relative flex flex-col text-left border min-h-[360px] transition-all duration-200"
                :class="selectedCleanser === cleanser.variantId ? 'border-ink bg-ink text-white shadow-strong' : 'border-rule bg-white text-ink hover:border-gold'"
                :disabled="!cleanser.variantId"
              >
                <div class="shrink-0 aspect-[1/1] sm:aspect-[3/4] overflow-hidden bg-parchment">
                  <img
                    x-show="cleanser.imageUrl"
                    :src="cleanser.imageUrl"
                    :alt="cleanser.imageAlt || cleanser.title"
                    class="w-full h-full object-cover object-top"
                    loading="lazy"
                  />
                  <div x-show="!cleanser.imageUrl" class="w-full h-full flex items-center justify-center">
                    <span class="font-display text-4xl text-rule">CFC</span>
                  </div>
                </div>
                <span
                  x-show="selectedCleanser === cleanser.variantId"
                  class="absolute -top-[15px] left-1/2 -translate-x-1/2 z-10 bg-gold text-ink font-mono text-[9px] tracking-[0.16em] uppercase px-4 py-1.5 whitespace-nowrap"
                >Selected</span>
                <div class="p-5 flex-1">
                  <span class="block font-display text-[22px] leading-tight" x-text="cleanser.shortTitle || cleanser.title"></span>
                  <span class="block font-mono text-[10px] text-gold mt-2" x-text="cleanser.formattedPrice"></span>
                  <span
                    class="block font-sans text-[12px] leading-relaxed mt-3"
                    :class="selectedCleanser === cleanser.variantId ? 'text-[rgba(255,255,255,0.7)]' : 'text-ink-soft'"
                    x-text="cleanser.description"
                  ></span>
                  <span
                    class="block font-sans font-light text-[12px] leading-relaxed mt-4"
                    :class="selectedCleanser === cleanser.variantId ? 'text-[rgba(255,255,255,0.62)]' : 'text-ink-soft'"
                    x-text="cleanser.details"
                  ></span>
                  <span class="block font-mono text-[9px] tracking-[0.16em] uppercase text-gold mt-5">
                    <span x-show="selectedCleanser === cleanser.variantId">Included in your system</span>
                    <span x-show="selectedCleanser !== cleanser.variantId">Choose this cleanser</span>
                  </span>
                </div>
              </button>
            </template>
          </div>
        </div>

        <div class="p-6 sm:p-8 lg:p-10 border-b border-rule">
          <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-3 mb-6">
            <div>
              <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">Step 02</span>
              <h2 class="font-display text-[32px] leading-tight text-ink mt-2">The CFC Glow</h2>
            </div>
            <p class="font-sans font-light text-[13px] leading-relaxed text-ink-soft">
              These products are automatically included based on the system you selected.
            </p>
          </div>
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 pt-4">
            <template x-for="item in includedTreatments()" :key="item.variantId || item.handle">
              <div class="relative border border-rule bg-white min-h-[280px]">
                <span class="absolute -top-[15px] left-1/2 -translate-x-1/2 z-10 bg-ink text-white font-mono text-[9px] tracking-[0.16em] uppercase px-4 py-1.5 whitespace-nowrap">Included</span>
                <div class="aspect-[1/1] sm:aspect-[3/4] overflow-hidden bg-parchment">
                  <img
                    x-show="item.imageUrl"
                    :src="item.imageUrl"
                    :alt="item.imageAlt || item.title"
                    class="w-full h-full object-cover object-top"
                    loading="lazy"
                  />
                  <div x-show="!item.imageUrl" class="w-full h-full flex items-center justify-center">
                    <span class="font-display text-4xl text-rule">CFC</span>
                  </div>
                </div>
                <div class="p-5">
                  <span class="block font-display text-[21px] leading-tight text-ink" x-text="item.title"></span>
                  <span class="block font-mono text-[10px] text-gold mt-3" x-text="item.formattedPrice"></span>
                  <span class="block font-sans text-[12px] leading-relaxed text-ink-soft mt-3" x-text="item.description"></span>
                  <span class="block font-sans font-light text-[12px] leading-relaxed text-ink-soft mt-3" x-text="item.details"></span>
                </div>
              </div>
            </template>
          </div>

          <div x-show="currentSystem().retinolIds.length > 0" class="mt-5" x-cloak>
            <div class="mb-4">
              <span class="font-mono text-[10px] tracking-[0.18em] uppercase text-gold">Premium Collection Also Includes</span>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 pt-4 max-w-[680px] mx-auto">
              <template x-for="retinol in includedRetinols()" :key="retinol.variantId || retinol.handle">
                <div class="relative border border-rule bg-white min-h-[260px] max-h-[610px] overflow-hidden">
                  <span class="absolute -top-[15px] left-1/2 -translate-x-1/2 z-10 bg-ink text-white font-mono text-[9px] tracking-[0.16em] uppercase px-4 py-1.5 whitespace-nowrap">Included</span>
                  <div class="aspect-[1/1] sm:aspect-[3/4] overflow-hidden bg-parchment">
                    <img
                      x-show="retinol.imageUrl"
                      :src="retinol.imageUrl"
                      :alt="retinol.imageAlt || retinol.title"
                      class="w-full h-full object-cover object-top"
                      loading="lazy"
                    />
                    <div x-show="!retinol.imageUrl" class="w-full h-full flex items-center justify-center">
                      <span class="font-display text-4xl text-rule">CFC</span>
                    </div>
                  </div>
                  <div class="p-5">
                    <span class="block font-display text-[21px] leading-tight text-ink" x-text="retinol.title"></span>
                    <span class="block font-mono text-[10px] text-gold mt-3" x-text="retinol.formattedPrice"></span>
                    <span class="block font-sans text-[12px] leading-relaxed text-ink-soft mt-3" x-text="retinol.description"></span>
                    <span class="block font-sans font-light text-[12px] leading-relaxed text-ink-soft mt-3" x-text="retinol.details"></span>
                  </div>
                </div>
              </template>
            </div>
          </div>
        </div>

        <div class="p-6 sm:p-8 lg:p-10">
          <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-3 mb-6">
            <div>
              <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">Step 03</span>
              <h2 class="font-display text-[32px] leading-tight text-ink mt-2">Choose your sunscreen.</h2>
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 pt-4 max-w-[680px] mx-auto">
            <template x-for="spf in products.spf" :key="spf.variantId || spf.handle">
              <button
                type="button"
                @click="selectedSpf = spf.variantId"
                class="relative flex flex-col text-left border min-h-[320px] max-h-[610px] overflow-hidden transition-all duration-200"
                :class="selectedSpf === spf.variantId ? 'bg-ink text-white border-ink shadow-strong' : 'bg-white text-ink border-rule hover:border-gold'"
                :disabled="!spf.variantId"
              >
                <div class="shrink-0 aspect-[1/1] sm:aspect-[3/4] overflow-hidden bg-parchment">
                  <img
                    x-show="spf.imageUrl"
                    :src="spf.imageUrl"
                    :alt="spf.imageAlt || spf.title"
                    class="w-full h-full object-cover object-top"
                    loading="lazy"
                  />
                  <div x-show="!spf.imageUrl" class="w-full h-full flex items-center justify-center">
                    <span class="font-display text-4xl text-rule">CFC</span>
                  </div>
                </div>
                <span
                  x-show="selectedSpf === spf.variantId"
                  class="absolute -top-[15px] left-1/2 -translate-x-1/2 z-10 bg-gold text-ink font-mono text-[9px] tracking-[0.16em] uppercase px-4 py-1.5 whitespace-nowrap"
                >Selected</span>
                <div class="p-5 flex-1">
                  <span class="block font-display text-[21px] leading-tight" x-text="spf.title"></span>
                  <span class="block font-mono text-[10px] text-gold mt-2" x-text="spf.formattedPrice"></span>
                  <span
                    class="block font-sans text-[12px] mt-3"
                    :class="selectedSpf === spf.variantId ? 'text-[rgba(255,255,255,0.7)]' : 'text-ink-soft'"
                    x-text="spf.description"
                  ></span>
                </div>
              </button>
            </template>
          </div>
        </div>
      <div class="bg-ink text-white p-6 sm:p-8 lg:p-10">
        <div class="max-w-md mx-auto text-center">
          <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">Your System</span>
          <h2 class="font-display text-[34px] leading-tight mt-3 mb-2" x-text="currentSystem().name"></h2>
          <p class="font-sans font-light text-[13px] leading-relaxed text-[rgba(255,255,255,0.58)]">
            Review your selected system before adding it to the cart.
          </p>

          <div class="space-y-4 mt-8 pt-7 border-t border-[rgba(255,255,255,0.08)]">
            <template x-for="item in selectedItems()" :key="item.variantId || item.handle">
              <div class="flex items-start justify-between gap-5 text-left font-sans font-light text-[13px] leading-relaxed text-[rgba(255,255,255,0.72)]">
                <span x-text="item.title"></span>
                <span class="font-mono text-[10px] text-gold shrink-0 pt-1" x-text="item.formattedPrice"></span>
              </div>
            </template>
          </div>

          <div class="mt-8 pt-7 border-t border-[rgba(255,255,255,0.08)]">
            <span class="block font-mono text-[10px] tracking-[0.18em] uppercase text-[rgba(255,255,255,0.48)]">System Total</span>
            <span class="block font-display text-[52px] leading-none mt-2" x-text="formatPrice(selectedTotal())"></span>
          </div>

          <button
            type="button"
            @click="addSystem()"
            class="w-full mt-8 bg-gold text-ink font-mono text-[10px] tracking-[0.18em] uppercase py-4 transition-colors duration-200 hover:bg-[oklch(80%_0.08_78)] disabled:opacity-60"
            :disabled="$store.cart.isLoading || selectedItems().some((item) => !item.variantId)"
          >
            <span x-show="!$store.cart.isLoading">Add System To Cart</span>
            <span x-show="$store.cart.isLoading">Adding System</span>
          </button>

          <p class="font-sans font-light text-[12px] leading-relaxed text-[rgba(255,255,255,0.52)] mt-4">
            This builder helps you choose a routine. After these items are in your cart, you can add, remove, or adjust products directly in the cart.
          </p>
        </div>
      </div>

    </div>
  </div>

  <div
    x-show="showUpsellModal"
    x-cloak
    x-transition:enter="transition ease-out duration-500"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-250"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    @keydown.escape.window="showUpsellModal = false"
    class="fixed inset-0 z-50 flex items-center justify-center bg-[rgba(0,0,0,0.58)] px-4 py-8"
    role="dialog"
    aria-modal="true"
    aria-labelledby="system-upsell-title"
  >
    <div class="absolute inset-0" @click="showUpsellModal = false"></div>
    <div
      class="relative bg-white w-full max-w-3xl max-h-[90vh] overflow-y-auto shadow-strong"
      x-transition:enter="transition ease-out duration-500"
      x-transition:enter-start="opacity-0 translate-y-5 scale-[0.98]"
      x-transition:enter-end="opacity-100 translate-y-0 scale-100"
      x-transition:leave="transition ease-in duration-200"
      x-transition:leave-start="opacity-100 translate-y-0 scale-100"
      x-transition:leave-end="opacity-0 translate-y-3 scale-[0.98]"
    >
      <button
        type="button"
        @click="showUpsellModal = false"
        class="absolute right-4 top-4 z-10 size-10 border border-rule bg-white font-mono text-[14px] text-ink hover:border-ink transition-colors duration-200"
        aria-label="Close"
      >
        &times;
      </button>

      <div class="p-6 sm:p-8 text-center max-w-xl mx-auto">
        <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">Complete Your Routine</span>
        <h2 id="system-upsell-title" class="font-display text-[34px] leading-tight text-ink mt-3">
          Pair with your Premium Collection.
        </h2>
        <p class="font-sans font-light text-[13px] leading-relaxed text-ink-soft mt-3">
          Your system is in the cart. Add either finishing product now, or continue to your cart.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-[680px] mx-auto px-6 sm:px-8 pb-6 sm:pb-8">
        <template x-for="item in products.upsells" :key="item.variantId || item.handle">
          <div class="h-[367px] max-h-[610px] border border-rule bg-white overflow-hidden flex flex-col">
            <div class="h-[215px] shrink-0 overflow-hidden bg-parchment">
              <img
                x-show="item.imageUrl"
                :src="item.imageUrl"
                :alt="item.imageAlt || item.title"
                class="w-full h-full object-cover object-top"
                loading="lazy"
              />
              <div x-show="!item.imageUrl" class="w-full h-full flex items-center justify-center">
                <span class="font-display text-4xl text-rule">CFC</span>
              </div>
            </div>
            <div class="p-4 flex-1 flex flex-col">
              <div class="flex items-start justify-between gap-4">
                <a :href="`/products/${item.handle}`" class="font-display text-[19px] leading-tight text-ink hover:text-gold transition-colors duration-200" x-text="item.title"></a>
                <span class="font-mono text-[10px] text-gold shrink-0" x-text="item.formattedPrice"></span>
              </div>
              <button
                type="button"
                @click="addUpsell(item)"
                class="mt-auto border border-ink text-ink font-mono text-[9px] tracking-[0.14em] uppercase px-4 py-3 hover:bg-ink hover:text-white transition-colors duration-200 disabled:opacity-50"
                :disabled="!item.variantId || $store.cart.isLoading"
              >
                Add To Cart
              </button>
            </div>
          </div>
        </template>
      </div>

      <div class="border-t border-rule px-6 sm:px-8 py-5 text-center">
        <button
          type="button"
          @click="showUpsellModal = false; $store.cart.open()"
          class="font-mono text-[10px] tracking-[0.16em] uppercase text-ink hover:text-gold transition-colors duration-200"
        >
          Continue To Cart
        </button>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  function systemWizard(data) {
    const money = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' });

    return {
      products: data.products,
      systems: data.systems,
      selectedSystem: 'complete',
      selectedCleanser: data.products.cleansers[0]?.variantId || '',
      selectedSpf: data.products.spf[0]?.variantId || '',
      showUpsellModal: false,

      currentSystem() {
        return this.systems.find((system) => system.id === this.selectedSystem) || this.systems[0];
      },
      findByVariant(collection, variantId) {
        return collection.find((item) => item.variantId === variantId) || collection[0];
      },
      selectedCleanserProduct() {
        return this.findByVariant(this.products.cleansers, this.selectedCleanser);
      },
      selectedSpfProduct() {
        return this.findByVariant(this.products.spf, this.selectedSpf);
      },
      includedTreatments() {
        return this.currentSystem().treatmentIds.map((id) => this.products.treatments[id]);
      },
      includedRetinols() {
        return this.currentSystem().retinolIds.map((id) => this.products.retinols[id]);
      },
      selectedItems() {
        return [
          this.selectedCleanserProduct(),
          ...this.includedTreatments(),
          this.selectedSpfProduct(),
          ...this.includedRetinols(),
        ].filter(Boolean);
      },
      selectedTotal() {
        return this.selectedItems().reduce((total, item) => total + (Number(item.price) || 0), 0);
      },
      systemPriceRange(system) {
        const treatmentTotal = system.treatmentIds.reduce((total, id) => total + (Number(this.products.treatments[id]?.price) || 0), 0);
        const retinolTotal = system.retinolIds.reduce((total, id) => total + (Number(this.products.retinols[id]?.price) || 0), 0);
        const totals = this.products.cleansers.flatMap((cleanser) =>
          this.products.spf.map((spf) => (Number(cleanser.price) || 0) + treatmentTotal + retinolTotal + (Number(spf.price) || 0))
        );
        const min = Math.min(...totals);
        const max = Math.max(...totals);

        if (!Number.isFinite(min) || !Number.isFinite(max)) return '$0';
        if (min === max) return this.formatPrice(min);
        return `${this.formatPrice(min)}-${this.formatPrice(max)}`;
      },
      formatPrice(amount) {
        return money.format(Number(amount) || 0);
      },
      async addSystem() {
        const shouldShowUpsell = this.selectedSystem === 'premium' && this.products.upsells.length > 0;

        await this.$store.cart.addItems(
          this.selectedItems().map((item) => ({
            merchandiseId: item.variantId,
            quantity: 1,
          })),
          { openCart: !shouldShowUpsell }
        );

        if (!this.$store.cart.errorMessage && shouldShowUpsell) {
          this.showUpsellModal = true;
        }
      },
      async addUpsell(item) {
        if (!item?.variantId) return;
        this.showUpsellModal = false;
        await this.$store.cart.addItem(item.variantId);
      },
    };
  }
</script>
