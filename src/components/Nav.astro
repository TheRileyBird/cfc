---
import cfcLogo from '../assets/images/cfc-logo.png';
---
<header
  x-data="{ open: false }"
  class="fixed top-0 inset-x-0 z-50 bg-white border-b border-slate-100"
>
  <nav class="max-w-7xl mx-auto px-6 lg:px-16 flex items-center justify-between h-16">

    <!-- Logo: circle icon + text wordmark -->
    <a href="/" class="flex items-center gap-2.5">
      <img
        src={cfcLogo.src}
        alt="CFC Skincare"
        class="h-8 w-8 rounded-full object-cover shrink-0"
      />
      <span class="text-[11px] font-bold tracking-[0.28em] uppercase text-slate-900 leading-none">
        CFC Skincare
      </span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden lg:flex items-center gap-8">
      {[['The System', '#system'], ['Shop', '#products'], ['About', '#about'], ['Contact', '#contact']].map(([label, href]) => (
        <li>
          <a
            href={href}
            class="text-sm font-medium text-slate-500 hover:text-slate-900 transition-colors duration-200"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA -->
    <div class="hidden lg:block">
      <a
        href="https://www.cfcskincare.shop/collections/all"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center px-5 py-2.5 bg-[#B8950A] hover:bg-[#9A7D08] text-white text-sm font-semibold rounded-full transition-colors duration-200"
      >
        Shop Now
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      @click="open = !open"
      class="lg:hidden p-2 text-slate-600 hover:text-slate-900 transition-colors"
      aria-label="Menu"
    >
      <span x-show="!open" class="block space-y-1.5">
        <span class="block h-px w-6 bg-current"></span>
        <span class="block h-px w-4 bg-current ml-auto"></span>
      </span>
      <svg x-show="open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </nav>

  <!-- Mobile drawer -->
  <div
    x-show="open"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-2"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="lg:hidden bg-white border-t border-slate-100 px-6 pb-8 pt-5"
  >
    {[
      ['The System', '#system'],
      ['Shop', '#products'],
      ['About', '#about'],
      ['Contact', '#contact'],
    ].map(([label, href]) => (
      <a
        href={href}
        @click="open=false"
        class="block py-3.5 text-sm font-medium text-slate-600 hover:text-slate-900 border-b border-slate-100 last:border-0 transition-colors"
      >
        {label}
      </a>
    ))}
    <a
      href="https://www.cfcskincare.shop/collections/all"
      target="_blank"
      rel="noopener"
      class="mt-5 block text-center py-3 bg-[#B8950A] hover:bg-[#9A7D08] text-white text-sm font-semibold rounded-full transition-colors"
    >
      Shop Now
    </a>
  </div>
</header>
