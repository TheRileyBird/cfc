---
import cfcLogo from '../assets/images/cfc-logo.png';
---
<header
  x-data="{ open: false, scrolled: window.scrollY > 60 }"
  x-init="window.addEventListener('scroll', () => { scrolled = window.scrollY > 60 }, { passive: true })"
  :class="scrolled
    ? 'bg-[#FAF7F2]/95 backdrop-blur-md shadow-[0_1px_0_0_rgba(0,0,0,0.06)]'
    : 'bg-transparent'"
  class="fixed top-0 inset-x-0 z-50 transition-all duration-300"
>
  <nav
    :class="scrolled ? 'h-14 lg:h-16' : 'h-16 lg:h-20'"
    class="max-w-7xl mx-auto px-6 lg:px-16 flex items-center justify-between transition-all duration-300"
  >

    <!-- Logo -->
    <a href="/" class="flex items-center">
      <img
        src={cfcLogo.src}
        alt="CFC Skincare"
        class="h-8 w-auto lg:h-10 transition-all duration-300"
      />
    </a>

    <!-- Desktop links -->
    <ul class="hidden lg:flex items-center gap-10">
      {['The System', 'Shop', 'About', 'Contact'].map((label, i) => {
        const hrefs = ['#system', '#products', '#about', '#contact'];
        return (
          <li>
            <a
              href={hrefs[i]}
              :class="scrolled ? 'text-charcoal-600 hover:text-charcoal-900' : 'text-white/80 hover:text-white'"
              class="text-sm tracking-[0.15em] uppercase font-medium transition-colors duration-300 relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-px after:bg-[#C9A84C] hover:after:w-full after:transition-all after:duration-300"
            >
              {label}
            </a>
          </li>
        );
      })}
    </ul>

    <!-- CTA -->
    <div class="hidden lg:block">
      <a
        href="https://www.cfcskincare.shop/collections/all"
        target="_blank"
        rel="noopener"
        :class="scrolled
          ? 'border-[#B8950A] text-[#B8950A] hover:bg-[#B8950A] hover:text-white'
          : 'border-white/60 text-white hover:bg-white hover:text-charcoal-800'"
        class="px-6 py-2.5 border text-sm tracking-[0.18em] uppercase font-medium transition-all duration-300 rounded-full"
      >
        Shop Now
      </a>
    </div>

    <!-- Mobile toggle -->
    <button
      @click="open = !open"
      :class="scrolled ? 'text-charcoal-700' : 'text-white'"
      class="lg:hidden p-2 transition-colors"
      aria-label="Menu"
    >
      <span x-show="!open" class="block w-6 space-y-1.5">
        <span class="block h-px w-full bg-current"></span>
        <span class="block h-px w-4 bg-current ml-auto"></span>
      </span>
      <svg x-show="open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </nav>

  <!-- Mobile drawer -->
  <div
    x-show="open"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-2"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="lg:hidden bg-[#FAF7F2] border-t border-[#E8E0D5] px-6 pb-8 pt-5 space-y-1"
  >
    {[
      ['The System', '#system'],
      ['Shop', '#products'],
      ['About', '#about'],
      ['Contact', '#contact'],
    ].map(([label, href]) => (
      <a
        href={href}
        @click="open=false"
        class="block py-3 text-sm tracking-[0.15em] uppercase text-charcoal-600 hover:text-[#B8950A] font-medium border-b border-[#E8E0D5] last:border-0 transition-colors"
      >
        {label}
      </a>
    ))}
    <a
      href="https://www.cfcskincare.shop/collections/all"
      target="_blank"
      rel="noopener"
      class="mt-4 block text-center py-3 border border-[#B8950A] text-[#B8950A] text-sm tracking-[0.18em] uppercase font-medium rounded-full hover:bg-[#B8950A] hover:text-white transition-all"
    >
      Shop Now
    </a>
  </div>
</header>
