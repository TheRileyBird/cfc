---
import cfcLogo from '../assets/images/cfc-logo.png';
---

<div
  id="site-nav"
  x-data="{ open: false, scrolled: false }"
  x-init="window.addEventListener('scroll', () => { scrolled = window.scrollY > 60 })"
  class="fixed top-0 inset-x-0 z-50 transition-[background,border-color] duration-400"
  :class="scrolled ? 'scrolled' : ''"
>

  <!-- Announcement bar -->
  <div
    id="announcement"
    class="overflow-hidden transition-all duration-300 ease-in-out"
    :style="scrolled ? 'max-height: 0; opacity: 0' : 'max-height: 40px; opacity: 1'"
    style="background: oklch(13% 0.010 255);"
  >
    <div class="text-center py-2.5 px-6">
      <a
        href="/shop"
        class="font-mono text-[10px] tracking-[0.18em] uppercase"
        style="color: oklch(80% 0.08 78);"
      >
        Subscribe &amp; Save 30% Off &mdash; Shop Now
      </a>
    </div>
  </div>

  <!-- Main nav bar -->
  <nav
    class="relative flex items-center transition-all duration-300 ease-in-out"
    :class="scrolled ? 'h-[56px]' : 'h-[72px]'"
    style="max-width: 1440px; margin: 0 auto; padding: 0 40px;"
  >

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 shrink-0 z-10 group">
      <img
        src={cfcLogo.src}
        alt="CFC Skincare"
        class="w-10 h-10 rounded-full object-cover shrink-0 transition-transform duration-[600ms] ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:rotate-[15deg]"
      />
      <span class="hidden lg:block font-mono text-[11px] tracking-[0.22em] uppercase text-ink">CFC Skincare</span>
    </a>

    <!-- Desktop links — centered absolute -->
    <ul class="hidden lg:flex absolute left-1/2 -translate-x-1/2 items-center gap-10 list-none">
      {[
        ['The System', '/#system'],
        ['Shop', '/shop'],
        ['About', '/#about'],
        ['Contact', '/#contact'],
      ].map(([label, href]) => (
        <li>
          <a
            href={href}
            class="font-mono text-[10px] tracking-[0.18em] uppercase text-ink-soft hover:text-ink transition-colors duration-200 relative leading-none"
            style="padding-bottom: 3px;"
          >
            <span
              class="absolute bottom-0 left-0 h-px bg-gold transition-all duration-300"
              style="width: 0; right: 100%;"
            ></span>
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Right: icons + CTA -->
    <div class="hidden lg:flex items-center gap-5 ml-auto z-10">
      <button
        @click="$store.search.isOpen ? $store.search.close() : $store.search.open()"
        class="text-ink-soft hover:text-ink transition-colors"
        aria-label="Search"
      >
        <svg class="w-[17px] h-[17px]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <circle cx="11" cy="11" r="8"/>
          <path stroke-linecap="round" d="m21 21-4.35-4.35"/>
        </svg>
      </button>
      <a href="https://www.cfcskincare.shop/account" class="text-ink-soft hover:text-ink transition-colors" aria-label="Account">
        <svg class="w-[17px] h-[17px]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
          <circle cx="12" cy="7" r="4"/>
        </svg>
      </a>
      <button
        @click="$store.cart.open()"
        class="relative text-ink-soft hover:text-ink transition-colors"
        aria-label="Cart"
      >
        <svg class="w-[17px] h-[17px]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path stroke-linecap="round" d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        <span
          x-show="$store.cart.totalQuantity > 0"
          x-text="$store.cart.totalQuantity"
          class="absolute -top-2 -right-2 w-4 h-4 flex items-center justify-center bg-gold text-white text-[9px] font-bold rounded-full leading-none"
        ></span>
      </button>

      <!-- Divider -->
      <div class="w-px h-5 bg-rule mx-1"></div>

      <a
        href="/shop"
        class="inline-flex items-center bg-ink text-white font-mono text-[10px] tracking-[0.18em] uppercase transition-colors duration-200 hover:bg-gold-deep"
        style="padding: 10px 22px;"
      >
        Shop Now
      </a>
    </div>

    <!-- Mobile: icons + hamburger -->
    <div class="lg:hidden flex items-center gap-4 ml-auto">
      <button
        @click="$store.search.isOpen ? $store.search.close() : $store.search.open()"
        class="text-ink-soft hover:text-ink transition-colors"
        aria-label="Search"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <circle cx="11" cy="11" r="8"/>
          <path stroke-linecap="round" d="m21 21-4.35-4.35"/>
        </svg>
      </button>
      <button
        @click="$store.cart.open()"
        class="relative text-ink-soft hover:text-ink transition-colors"
        aria-label="Cart"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path stroke-linecap="round" d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        <span
          x-show="$store.cart.totalQuantity > 0"
          x-text="$store.cart.totalQuantity"
          class="absolute -top-2 -right-2 w-4 h-4 flex items-center justify-center bg-gold text-white text-[9px] font-bold rounded-full leading-none"
        ></span>
      </button>
      <button
        @click="open = !open"
        class="p-1.5 text-ink-soft hover:text-ink transition-colors"
        aria-label="Menu"
      >
        <span x-show="!open" class="block space-y-1.5">
          <span class="block h-px w-6 bg-current"></span>
          <span class="block h-px w-4 bg-current ml-auto"></span>
        </span>
        <svg x-show="open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile drawer -->
  <div
    x-show="open"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-2"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="lg:hidden bg-white border-t border-rule px-6 pb-8 pt-4"
  >
    {[
      ['The System', '/#system'],
      ['Shop', '/shop'],
      ['About', '/#about'],
      ['Contact', '/#contact'],
    ].map(([label, href]) => (
      <a
        href={href}
        @click="open=false"
        class="block py-3.5 font-mono text-[11px] tracking-[0.25em] uppercase text-ink-soft hover:text-ink border-b border-rule last:border-0 transition-colors"
      >
        {label}
      </a>
    ))}
    <div class="mt-5 flex gap-3">
      <a
        href="https://www.cfcskincare.shop/account"
        class="flex-1 text-center py-3 border border-rule text-ink font-mono text-[10px] tracking-[0.18em] uppercase hover:border-ink transition-colors"
      >
        Account
      </a>
      <a
        href="/shop"
        class="flex-1 text-center py-3 bg-ink text-white font-mono text-[10px] tracking-[0.18em] uppercase hover:bg-gold-deep transition-colors"
      >
        Shop Now
      </a>
    </div>
  </div>

  <!-- Search panel -->
  <div
    x-show="$store.search.isOpen"
    x-cloak
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="-translate-y-3 opacity-0"
    x-transition:enter-end="translate-y-0 opacity-100"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="-translate-y-3 opacity-0"
    @keydown.escape.window="$store.search.close()"
    class="bg-white border-b border-rule shadow-strong"
  >
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="flex items-center gap-3 py-4">
        <svg class="w-4 h-4 text-ink-soft shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <circle cx="11" cy="11" r="8"/>
          <path stroke-linecap="round" d="m21 21-4.35-4.35"/>
        </svg>
        <input
          type="text"
          placeholder="Search products…"
          x-model="$store.search.query"
          @input.debounce.300ms="$store.search.doSearch()"
          x-effect="if ($store.search.isOpen) $nextTick(() => $el.focus())"
          class="flex-1 text-sm text-ink placeholder-ink-soft border-0 outline-none bg-transparent font-sans"
          autocomplete="off"
        />
        <button
          @click="$store.search.close()"
          class="shrink-0 text-ink-soft hover:text-ink transition-colors p-1"
          aria-label="Close search"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <div x-show="$store.search.query.length > 0" class="pb-5">
        <div x-show="$store.search.isLoading" class="flex items-center justify-center py-6">
          <svg class="animate-spin w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
          </svg>
        </div>
        <div
          x-show="!$store.search.isLoading && $store.search.results.length === 0"
          class="py-5 text-center text-sm text-ink-soft font-sans"
        >
          No results for &ldquo;<span x-text="$store.search.query" class="font-medium text-ink"></span>&rdquo;
        </div>
        <div
          x-show="!$store.search.isLoading && $store.search.results.length > 0"
          class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-8 gap-3"
        >
          <template x-for="product in $store.search.results" :key="product.id">
            <a
              :href="`https://www.cfcskincare.shop/products/${product.handle}`"
              @click="$store.search.close()"
              class="group block"
            >
              <div class="aspect-square overflow-hidden bg-parchment">
                <img
                  :src="product.imageUrl"
                  :alt="product.imageAlt || product.title"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
              </div>
              <p class="font-mono text-[10px] tracking-[0.1em] uppercase mt-2 text-ink group-hover:text-gold transition-colors line-clamp-2 leading-snug" x-text="product.title"></p>
              <p class="font-mono text-[10px] text-ink-soft mt-0.5" x-text="$store.search.formatPrice(product.price)"></p>
            </a>
          </template>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  #site-nav.scrolled {
    background: rgba(253, 251, 247, 0.95);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid oklch(88% 0.006 72);
  }

  /* Nav link underline animation */
  nav ul a {
    position: relative;
  }
  nav ul a::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 1px;
    background: oklch(64% 0.115 72);
    transition: width 0.3s cubic-bezier(0.16,1,0.3,1);
  }
  nav ul a:hover::after {
    width: 100%;
  }
  nav ul a span {
    display: none;
  }
</style>
