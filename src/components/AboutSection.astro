---
import { Image } from 'astro:assets';
import founderImg from '../assets/images/family.jpg';
import productsImg from '../assets/images/group.jpg';
---

<section class="bg-slate-50 border-t border-slate-100" id="about">
  <div class="max-w-7xl mx-auto px-6 lg:px-16 py-24 lg:py-36">

    <!-- Top: text + founder image -->
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-stretch mb-16 lg:mb-20">

      <!-- Left: copy -->
      <div
        x-data
        x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
        class="opacity-0 translate-y-6 transition-all duration-700 lg:col-span-5"
      >
        <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-white border border-slate-200 rounded-full mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-[#B8950A] shrink-0"></span>
          <span class="text-[#B8950A] text-xs font-semibold tracking-[0.2em] uppercase">About CFC</span>
        </span>

        <h2 class="font-bold text-3xl lg:text-[2.6rem] text-slate-900 leading-tight mb-5">
          Built by someone who actually understands your skin.
        </h2>

        <p class="text-slate-500 leading-relaxed mb-4 text-base">
          CFC Skincare is the bridge between clinical efficacy and clean beauty — a medical-grade, plant-based system created by a nurse practitioner, formulated with a licensed cosmetic chemist, and built for women who are done guessing.
        </p>
        <p class="text-slate-500 leading-relaxed mb-10 text-base">
          Every formula is plant-based <em>and</em> medical-grade. Purity-tested. Locally produced in Louisiana. Designed around a protocol that works in under five minutes — at every age, every stage.
        </p>

        <!-- Credential grid -->
        <div class="grid grid-cols-2 gap-3">
          {[
            ['NP Founded', 'Clinical knowledge, not marketing'],
            ['Chemist Formulated', 'Medical-grade efficacy'],
            ['Purity-Tested', 'Every batch, every time'],
            ['Louisiana-Made', 'Full quality control'],
          ].map(([title, desc]) => (
            <div class="p-4 bg-white rounded-xl border border-slate-200 shadow-card">
              <p class="text-slate-900 text-sm font-semibold mb-1">{title}</p>
              <p class="text-slate-400 text-sm leading-snug">{desc}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: founder image -->
      <div
        x-data
        x-intersect.once="$el.classList.add('opacity-100', 'translate-x-0')"
        class="opacity-0 translate-x-6 transition-all duration-700 delay-150 lg:col-span-7 relative h-full"
      >
        <div class="rounded-2xl overflow-hidden shadow-lift h-full">
          <Image
            src={founderImg}
            alt="CFC Skincare — real woman showing results"
            class="w-full h-full object-cover object-top"
            widths={[600, 900, 1200]}
            sizes="(max-width: 1024px) 100vw, 58vw"
          />
        </div>
      </div>
    </div>

    <!-- Full-width testimonial callout -->
    <div class="-mx-6 lg:-mx-16 px-6 lg:px-16 py-12 lg:py-16 mb-16 lg:mb-20 text-center bg-white">
      <div class="flex justify-center gap-0.5 text-[#C9A84C] text-sm mb-5">★★★★★</div>
      <p class="font-serif text-2xl lg:text-3xl text-slate-700 leading-snug max-w-2xl mx-auto mb-4">
        "I stopped wearing foundation to work. I didn't even notice when it stopped feeling necessary."
      </p>
      <p class="text-slate-400 text-sm font-medium">— CFC Customer</p>
    </div>

    <!-- Bottom: products + USP -->
    <div
      x-data
      x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
      class="opacity-0 translate-y-6 transition-all duration-700 grid lg:grid-cols-2 gap-12 lg:gap-20 items-center"
    >
      <div class="relative rounded-2xl overflow-hidden shadow-lift">
        <Image
          src={productsImg}
          alt="CFC Skincare product collection"
          class="w-full object-cover"
          style="max-height: 480px;"
          widths={[500, 800]}
          sizes="(max-width: 1024px) 100vw, 50vw"
        />
      </div>

      <div>
        <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-white border border-slate-200 rounded-full mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-[#B8950A] shrink-0"></span>
          <span class="text-[#B8950A] text-xs font-semibold tracking-[0.2em] uppercase">The Difference</span>
        </span>
        <h3 class="font-bold text-2xl lg:text-3xl text-slate-900 leading-tight mb-6">
          The only medical-grade, plant-based system created by a nurse practitioner.
        </h3>
        <div class="space-y-4 mb-10">
          {[
            'vs. Luxury brands — clinical results at a fraction of the price, with transparent ingredients and direct access to the NP who created them.',
            'vs. Clinical brands — plant-based, locally made, and accessible without a dermatologist referral.',
            'vs. Clean beauty — formulated by a medical professional for efficacy, not just ingredient safety.',
          ].map(line => (
            <div class="flex gap-3 p-4 bg-white rounded-xl border border-slate-100 text-sm text-slate-600 leading-relaxed">
              <svg class="w-4 h-4 text-[#C9A84C] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              {line}
            </div>
          ))}
        </div>
        <a
          href="#contact"
          class="inline-flex items-center gap-2 text-sm font-semibold text-[#B8950A] hover:text-[#9A7D08] transition-colors group"
        >
          Request a consultation
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>

  </div>
</section>
