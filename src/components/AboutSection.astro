---
import { GraduationCap, Leaf, FlaskConical, MapPin } from '@lucide/astro';

const pillars = [
  { icon: GraduationCap, label: 'Nurse Practitioner Founded', desc: 'Clinical knowledge of skin physiology, not marketing expertise.' },
  { icon: FlaskConical, label: 'Chemist Formulated', desc: 'Medical-grade efficacy through rigorous scientific formulation.' },
  { icon: Leaf, label: 'Plant-Based & Purity-Tested', desc: 'Every batch verified for ingredient integrity and clean chemistry.' },
  { icon: MapPin, label: 'Louisiana-Made', desc: 'Bottled by the CFC team with full quality control and traceability.' },
];
---

<section class="py-24 lg:py-32 bg-white" id="about">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">

      <!-- Image side -->
      <div
        x-data
        x-intersect.once="$el.classList.add('opacity-100', 'translate-x-0')"
        class="opacity-0 -translate-x-8 transition-all duration-700 relative"
      >
        <div class="relative rounded-3xl overflow-hidden shadow-lift">
          <img
            src="https://images.unsplash.com/photo-1559839734-2b71ea197ec2?w=800&q=80&auto=format&fit=crop"
            alt="Nurse Practitioner founder of CFC Skincare"
            class="w-full aspect-[4/5] object-cover"
          />
          <!-- Decorative gold accent -->
          <div class="absolute bottom-0 left-0 right-0 h-1/3 bg-gradient-to-t from-charcoal-800/60 to-transparent"></div>
          <div class="absolute bottom-8 left-8 right-8">
            <div class="bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl p-5">
              <p class="font-serif text-white text-lg font-medium mb-1">"I was a nurse practitioner who couldn't find skincare she trusted — so I made it myself."</p>
              <p class="text-charcoal-300 text-sm">— CFC Skincare Founder, NP</p>
            </div>
          </div>
        </div>

        <!-- Floating credential badge -->
        <div class="absolute -top-4 -right-4 bg-gold-500 rounded-2xl p-4 shadow-lift text-center min-w-[100px]">
          <p class="font-serif text-3xl font-bold text-white">NP</p>
          <p class="text-gold-100 text-xs font-medium mt-0.5">Founded</p>
        </div>
      </div>

      <!-- Content side -->
      <div
        x-data
        x-intersect.once="$el.classList.add('opacity-100', 'translate-x-0')"
        class="opacity-0 translate-x-8 transition-all duration-700"
      >
        <div class="flex items-center gap-3 mb-4">
          <span class="w-8 h-px bg-gold-500"></span>
          <span class="text-gold-500 text-sm font-medium tracking-widest uppercase">About CFC</span>
        </div>

        <h2 class="font-serif text-3xl lg:text-4xl font-semibold text-charcoal-800 leading-tight mb-6">
          Built by someone who<br/>
          <span class="text-gold-500">actually understands your skin.</span>
        </h2>

        <p class="text-charcoal-500 leading-relaxed mb-6">
          CFC Skincare is the bridge between clinical efficacy and clean beauty — a medical-grade, plant-based system created by a nurse practitioner, formulated with a licensed cosmetic chemist, and built specifically for women who are done guessing.
        </p>

        <p class="text-charcoal-500 leading-relaxed mb-10">
          We eliminated the false choice between clean ingredients and clinical results. Every formula is plant-based <em>and</em> medical-grade. Purity-tested. Locally produced in Louisiana. Designed around a protocol that works in under five minutes.
        </p>

        <!-- Pillars grid -->
        <div class="grid grid-cols-2 gap-4">
          {pillars.map(({ icon: Icon, label, desc }) => (
            <div class="p-4 bg-cream-100 rounded-xl">
              <Icon class="w-5 h-5 text-gold-500 mb-2" />
              <p class="font-semibold text-charcoal-800 text-sm mb-1">{label}</p>
              <p class="text-charcoal-400 text-xs leading-relaxed">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
