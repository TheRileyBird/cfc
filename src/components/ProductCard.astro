---
import type { ShopifyProduct } from '../lib/shopify';
import { formatPrice } from '../lib/shopify';

export interface Props {
  product: ShopifyProduct;
}

const { product } = Astro.props;

const image = product.images.edges[0]?.node;
const variant = product.variants.edges[0]?.node;
const price = formatPrice(product.priceRange.minVariantPrice.amount);
const productPageUrl = `/products/${product.handle}`;
const step = product.tags.find(t => ['cleanse','treat','protect'].includes(t.toLowerCase()));
---

<article
  x-data="{ adding: false, added: false }"
  class="group flex flex-col h-full bg-white hover:bg-parchment-2 transition-colors duration-300 overflow-hidden"
>
  <!-- Product image: 3/4 aspect -->
  <a
    href={productPageUrl}
    class="block relative overflow-hidden bg-parchment aspect-[1/1] sm:aspect-[3/4]"
  >
    {image ? (
      <img
        src={image.url}
        alt={image.altText ?? product.title}
        class="w-full h-full object-cover transition-transform duration-[800ms] cubic-bezier(0.16,1,0.3,1) group-hover:scale-[1.06]"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center">
        <span class="font-display text-4xl text-rule">CFC</span>
      </div>
    )}

    {step && (
      <span class="absolute top-4 left-4 bg-white text-gold-deep font-mono text-[9px] tracking-[0.12em] uppercase px-2 py-1">
        {step}
      </span>
    )}
    {!product.availableForSale && (
      <span class="absolute top-4 right-4 bg-ink text-white font-mono text-[9px] tracking-[0.12em] uppercase px-2 py-1">
        Sold Out
      </span>
    )}
  </a>

  <!-- Product info -->
  <div class="p-5 flex flex-col flex-1">
    <a
      href={productPageUrl}
    >
      <h3 class="font-display text-[18px] font-normal text-ink leading-snug mb-1.5 line-clamp-2">
        {product.title}
      </h3>
    </a>
    <p class="font-sans font-light text-[12px] text-ink-soft leading-relaxed line-clamp-2 mb-4 flex-1">
      {product.description || ' '}
    </p>
    <div class="flex items-center justify-between mt-auto">
      <span class="font-display text-[20px] font-normal text-ink">{price}</span>

      {product.availableForSale && variant ? (
        <button
          @click={`if (!adding && !added) {
            adding = true;
            await $store.cart.addItem('${variant.id}');
            adding = false;
            added = true;
            setTimeout(() => { added = false; }, 1800);
          }`}
          :class="added ? 'bg-ink text-white border-ink' : 'bg-white text-ink border-ink hover:bg-ink hover:text-white'"
          class="font-mono text-[9px] tracking-[0.12em] uppercase border px-3 py-2 transition-all duration-200"
          :disabled="adding"
        >
          <span x-show="!adding && !added">Add to Cart</span>
          <span x-show="adding">Adding…</span>
          <span x-show="added">Added ✓</span>
        </button>
      ) : (
        <a
          href={`https://www.cfcskincare.shop/products/${product.handle}`}
          class="font-mono text-[9px] tracking-[0.12em] uppercase border border-rule text-ink-soft px-3 py-2 hover:border-ink hover:text-ink transition-colors duration-200"
        >
          View Product
        </a>
      )}
    </div>
  </div>
</article>
