---
import type { ShopifyProduct } from '../lib/shopify';
import { formatPrice, getCheckoutUrl } from '../lib/shopify';
import { ShoppingBag } from '@lucide/astro';

export interface Props {
  product: ShopifyProduct;
}

const { product } = Astro.props;

const image = product.images.edges[0]?.node;
const variant = product.variants.edges[0]?.node;
const price = formatPrice(product.priceRange.minVariantPrice.amount);
const checkoutUrl = variant && product.availableForSale ? getCheckoutUrl(variant.id) : `https://www.cfcskincare.shop/products/${product.handle}`;
const step = product.tags.find(t => ['cleanse','treat','protect'].includes(t.toLowerCase()));
const stepColors: Record<string, string> = {
  cleanse: 'bg-slate-100 text-slate-600',
  treat:   'bg-gold-50 text-gold-600',
  protect: 'bg-slate-100 text-slate-600',
};
---

<article class="group flex flex-col bg-white rounded-2xl overflow-hidden border border-slate-200 shadow-card hover:shadow-lift transition-all duration-300 hover:-translate-y-1">
  <!-- Product image -->
  <a href={`https://www.cfcskincare.shop/products/${product.handle}`} target="_blank" rel="noopener" class="block relative overflow-hidden aspect-square bg-slate-50">
    {image ? (
      <img
        src={image.url}
        alt={image.altText ?? product.title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center">
        <span class="font-serif text-4xl text-slate-300">CFC</span>
      </div>
    )}
    {step && (
      <span class={`absolute top-3 left-3 px-2.5 py-1 rounded-full text-xs font-semibold capitalize tracking-wide ${stepColors[step.toLowerCase()] ?? 'bg-slate-100 text-slate-500'}`}>
        {step}
      </span>
    )}
    {!product.availableForSale && (
      <span class="absolute top-3 right-3 px-2.5 py-1 rounded-full bg-slate-900 text-white text-xs font-semibold tracking-wide">
        Out of stock
      </span>
    )}
  </a>

  <!-- Product info -->
  <div class="p-5 flex flex-col flex-1">
    <a href={`https://www.cfcskincare.shop/products/${product.handle}`} target="_blank" rel="noopener">
      <h3 class="font-semibold text-sm text-slate-900 leading-snug mb-1.5 group-hover:text-[#B8950A] transition-colors line-clamp-2">
        {product.title}
      </h3>
    </a>
    <p class="text-slate-400 text-sm leading-relaxed line-clamp-2 mb-4 flex-1">
      {product.description}
    </p>
    <div class="flex items-center justify-between mt-auto">
      <span class="font-bold text-slate-900 text-sm">{price}</span>
      <a
        href={checkoutUrl}
        target="_blank"
        rel="noopener"
        class={`flex items-center gap-1.5 px-4 py-2 text-white text-xs font-semibold rounded-full transition-colors ${
          product.availableForSale
            ? 'bg-[#B8950A] hover:bg-[#9A7D08]'
            : 'bg-slate-400 hover:bg-slate-500'
        }`}
      >
        <ShoppingBag class="w-3.5 h-3.5" />
        {product.availableForSale ? 'Add to Cart' : 'View Product'}
      </a>
    </div>
  </div>
</article>
