---
import { Image } from 'astro:assets';
import heroImage from '../assets/images/imgi_13_tt-102_1500x.jpg';
import productImage from '../assets/images/imgi_3_Body_care.png';
---

<section class="bg-[#f6f0e7] pt-28 lg:pt-36 pb-14 lg:pb-24 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-16">
    <div class="grid lg:grid-cols-[1.05fr_0.95fr] gap-12 lg:gap-16 items-center">
      <div>
        <div
          x-data
          x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
          class="opacity-0 translate-y-4 transition-all duration-700"
        >
          <p class="mb-5 text-sm tracking-[0.24em] uppercase text-[#9a7d3f] font-medium">NP Created · Plant Based · Medical Grade</p>
          <h1 class="font-serif text-[clamp(3.25rem,7vw,6.5rem)] leading-[0.94] text-charcoal-800 max-w-3xl">
            Gentle formulas
            <br />
            for skin that
            <br />
            <em class="italic text-[#b99649]">wants results.</em>
          </h1>
          <p class="mt-6 max-w-xl text-lg leading-relaxed text-charcoal-500">
            CFC Skincare pairs nurse practitioner guidance with clinical, plant-based formulas that keep your routine simple, calm, and visibly effective.
          </p>
        </div>

        <div
          x-data
          x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
          class="opacity-0 translate-y-4 transition-all duration-700 delay-100 mt-8 flex flex-col sm:flex-row sm:items-center gap-4"
        >
          <a
            href="#products"
            class="inline-flex items-center justify-center rounded-full bg-charcoal-800 px-7 py-3.5 text-sm uppercase tracking-[0.18em] text-white transition-colors hover:bg-[#b99649]"
          >
            Shop Now
          </a>
          <a
            href="#system"
            class="inline-flex items-center justify-center rounded-full border border-[#d9c8ae] px-7 py-3.5 text-sm uppercase tracking-[0.18em] text-charcoal-700 transition-colors hover:border-[#b99649] hover:text-[#b99649]"
          >
            Explore The Routine
          </a>
        </div>

        <div
          x-data
          x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
          class="opacity-0 translate-y-4 transition-all duration-700 delay-200 mt-12 grid gap-4 sm:grid-cols-3"
        >
          {[
            ['3 steps', 'Cleanse, treat, and protect in under five minutes.'],
            ['Clinically balanced', 'Made to support brighter, calmer, more even skin.'],
            ['Made in Louisiana', 'Small-batch oversight with real practitioner input.'],
          ].map(([title, copy]) => (
            <div class="rounded-[1.75rem] border border-[#e4d7c3] bg-[#fbf7f0] p-5">
              <p class="text-sm uppercase tracking-[0.18em] text-[#9a7d3f]">{title}</p>
              <p class="mt-3 text-sm leading-relaxed text-charcoal-500">{copy}</p>
            </div>
          ))}
        </div>
      </div>

      <div
        x-data
        x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
        class="opacity-0 translate-y-5 transition-all duration-700 delay-150 relative"
      >
        <div class="relative overflow-hidden rounded-[2.5rem] bg-[#ece1d0] p-4 shadow-[0_24px_80px_rgba(64,45,20,0.12)]">
          <Image
            src={heroImage}
            alt="CFC skincare hero image"
            class="h-[520px] w-full rounded-[2rem] object-cover object-top"
            widths={[700, 1100, 1500]}
            sizes="(max-width: 1024px) 100vw, 42vw"
          />
        </div>

        <div class="absolute -bottom-8 left-4 right-4 sm:left-auto sm:right-8 sm:w-[320px] rounded-[2rem] border border-[#eadbc5] bg-[#fffdf8] p-5 shadow-[0_18px_40px_rgba(64,45,20,0.12)]">
          <div class="flex items-start gap-4">
            <div class="h-20 w-20 overflow-hidden rounded-[1.25rem] bg-[#f4ede2]">
              <Image
                src={productImage}
                alt="CFC skincare collection"
                class="h-full w-full object-cover"
                widths={[160, 320]}
                sizes="80px"
              />
            </div>
            <div class="flex-1">
              <p class="text-xs uppercase tracking-[0.22em] text-[#9a7d3f]">Featured Routine</p>
              <h2 class="mt-2 font-serif text-2xl leading-tight text-charcoal-800">Your everyday glow set.</h2>
              <p class="mt-2 text-sm leading-relaxed text-charcoal-500">A cleanser, corrective serum, and SPF designed to work together without overcomplicating your shelf.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
