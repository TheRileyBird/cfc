---
import { Image } from 'astro:assets';
import heroImage from '../assets/images/imgi_12_tt-75_1500x.jpg';
import productImage from '../assets/images/imgi_71_tt-116_0f7352c9-4007-4f7a-a8a5-032982aed8f6_375x.jpg';
---

<section class="bg-[#f6f0e7] py-20 pb-0 overflow-hidden">
  <div class="mx-auto px-6 lg:px-16">
    <div
      x-data
      x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
      class="opacity-0 translate-y-4 transition-all duration-700 relative overflow-hidden rounded-[2rem] lg:rounded-[2.25rem] min-h-[680px] lg:min-h-[760px] bg-[#cab391]"
    >
      <Image
        src={heroImage}
        alt="CFC skincare hero image"
        class="absolute inset-0 h-full w-full object-cover object-center"
        widths={[900, 1400, 1800]}
        sizes="100vw"
      />
      <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(41,27,14,0.46)_0%,rgba(41,27,14,0.18)_32%,rgba(41,27,14,0.08)_60%,rgba(41,27,14,0.12)_100%)]"></div>
      <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(255,250,241,0.06)_0%,rgba(21,12,8,0.14)_100%)]"></div>

      <div class="relative z-10 flex min-h-[680px] lg:min-h-[760px] items-end p-8 sm:p-10 lg:p-14">
        <div class="mx-auto grid w-full max-w-[1100px] items-end gap-10 lg:grid-cols-[0.95fr_1.05fr]">
          <div class="max-w-[380px] pt-8 lg:pt-0">
            <h1 class="font-serif text-[clamp(3.4rem,7vw,5.8rem)] leading-[0.93] text-white">
              Glow
              <br />
              naturally
              <br />
              every day
            </h1>
            <p class="mt-6 max-w-[330px] text-[1.05rem] leading-relaxed text-white/85">
              Discover our skincare essentials, crafted with clinical care and powered by nature.
            </p>
            <a
              href="#products"
              class="mt-10 inline-flex items-center justify-center rounded-[1.35rem] bg-white px-8 py-5 font-serif text-[1.1rem] text-[#4b312d] transition-colors hover:bg-[#f6eee4]"
            >
              Shop now
            </a>
          </div>

          <div class="relative flex min-h-[280px] items-end justify-end">
            <div class="w-full max-w-[360px] rounded-[1.75rem] bg-white p-6 shadow-[0_18px_40px_rgba(0,0,0,0.16)]">
              <h2 class="max-w-[220px] font-serif text-[1.15rem] leading-[1.2] text-[#4d3a34] sm:text-[1.35rem]">
                Ultra-Gentle foaming
                <br />
                facial cleanser
              </h2>
              <div class="mt-5 overflow-hidden rounded-[1.4rem] bg-[#f1eadf] p-5">
                <Image
                  src={productImage}
                  alt="Featured CFC cleanser"
                  class="mx-auto h-[220px] w-auto object-contain"
                  widths={[220, 440]}
                  sizes="220px"
                />
              </div>
              <div class="mt-5 flex items-end gap-2 font-sans">
                <span class="text-[1rem] font-semibold text-[#3c2b27]">$79.00 USD</span>
                <span class="text-[0.9rem] text-[#8c7f79] line-through">$99.00 USD</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
