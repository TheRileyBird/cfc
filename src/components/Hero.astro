---
import videoSrc from '../assets/videos/stock-video.mp4';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-[100px]">

  <!-- Video background -->
  <video
    autoplay
    muted
    loop
    playsinline
    class="absolute inset-0 w-full h-full object-cover"
  >
    <source src={videoSrc} type="video/mp4" />
  </video>

  <!-- Overlays -->
  <div class="absolute inset-0 bg-slate-900/65"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-slate-900/50 via-transparent to-slate-900/20"></div>

  <!-- Content: centered -->
  <div class="relative z-10 w-full max-w-4xl mx-auto px-6 lg:px-8 text-center">

    <!-- Credential badge -->
    <div
      x-data
      x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
      class="opacity-0 translate-y-3 transition-all duration-700 flex justify-center mb-8"
    >
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 backdrop-blur-sm border border-white/20">
        <!--<span class="w-1.5 h-1.5 rounded-full bg-[#C9A84C] shrink-0"></span>-->
        <span class="text-white/90 text-xs font-semibold tracking-[0.18em] uppercase">
          Medical-Grade · Plant-Based
        </span>
      </span>
    </div>

    <!-- Headline -->
    <h1
      x-data
      x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
      class="opacity-0 translate-y-5 transition-all duration-700 delay-100 font-bold text-5xl sm:text-6xl lg:text-[5.5rem] leading-[1.04] tracking-tight text-white mb-12"
    >
      Clinical Skincare.<br/>
      <span class="text-[#C9A84C]">Designed for You.</span>
    </h1>

    <!-- Step indicators -->
    <div
        x-data
        x-intersect.once="$el.classList.add('opacity-100')"
        class="opacity-0 transition-all duration-700 delay-500 my-12 flex items-center justify-center gap-6 sm:gap-10"
    >
      {['Cleanse', 'Treat', 'Protect'].map((s, i) => (
          <div class="flex items-center gap-2.5">
            <span class="text-white/30 text-sm tracking-[0.2em] uppercase font-medium tabular-nums">0{i+1}</span>
            <span class="text-white/55 text-sm tracking-[0.15em] uppercase font-semibold">{s}</span>
            {i < 2 && <span class="hidden sm:block w-6 h-px bg-white/15 ml-2"></span>}
          </div>
      ))}
    </div>

    <!-- Subtext -->
    <!--<p-->
    <!--  x-data-->
    <!--  x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"-->
    <!--  class="opacity-0 translate-y-5 transition-all duration-700 delay-200 text-white/65 text-xs font-light max-w-sm mx-auto mb-10 leading-relaxed"-->
    <!--&gt;-->
    <!-- 3 steps, 5 minutes-->
    <!--</p>-->

    <!-- CTAs -->
    <div
      x-data
      x-intersect.once="$el.classList.add('opacity-100', 'translate-y-0')"
      class="opacity-0 translate-y-5 transition-all duration-700 delay-300 flex flex-col sm:flex-row items-center justify-center gap-3"
    >
      <a
        href="#system"
        class="px-8 py-3.5 bg-[#B8950A] hover:bg-[#9A7D08] text-white text-sm font-semibold rounded-full transition-colors duration-200 min-w-[200px]"
      >
        Discover the System
      </a>
      <a
        href="/shop"
        class="px-8 py-3.5 bg-white/10 hover:bg-white/20 backdrop-blur-sm border border-white/25 text-white text-sm font-semibold rounded-full transition-all duration-200 min-w-[200px]"
      >
        Shop Products
      </a>
    </div>

  </div>

  <!-- Scroll nudge -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 z-10">
    <span class="text-white/30 text-xs tracking-[0.2em] uppercase font-medium">Scroll</span>
    <div class="w-px h-7 bg-gradient-to-b from-white/30 to-transparent animate-pulse mt-1"></div>
  </div>
</section>
