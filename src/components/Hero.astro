---
import videoSrc from '../assets/videos/stock-video.mp4';
---

<section id="hero" class="relative overflow-hidden" style="height: 100svh; min-height: 600px; display: flex; align-items: flex-end;">

  <!-- Background: video with image fallback -->
  <div id="hero-bg" class="absolute inset-0" style="background: oklch(13% 0.010 255);">
    <video
      id="hero-video"
      autoplay
      muted
      loop
      playsinline
      class="w-full h-full object-cover object-[center_30%]"
      style="opacity: 0.5; transform: scale(1.04); transition: transform 8s cubic-bezier(0.16,1,0.3,1), opacity 1.2s ease;"
    >
      <source src={videoSrc} type="video/mp4" />
    </video>
  </div>

  <!-- Overlay gradient -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: linear-gradient(to top, oklch(13% 0.010 255 / 0.92) 0%, oklch(13% 0.010 255 / 0.30) 45%, oklch(13% 0.010 255 / 0.15) 100%);"
  ></div>

  <!-- Content -->
  <div
    class="relative z-10 w-full grid grid-cols-1 lg:grid-cols-2 gap-10 items-end"
    style="max-width: 1440px; margin: 0 auto; padding: 0 40px 80px;"
  >

    <!-- Left: headline -->
    <div>
      <!-- Eyebrow -->
      <div class="flex items-center gap-3 mb-6 reveal" style="transition-delay: 0.1s;">
        <div class="h-px bg-gold" style="width: 32px;"></div>
        <span class="font-mono text-[10px] tracking-[0.2em] uppercase" style="color: rgba(255,255,255,0.5);">
          Medical-Grade · Plant-Based · NP-Founded
        </span>
      </div>

      <!-- H1 -->
      <h1
        class="font-display font-light text-white reveal"
        style="font-size: clamp(64px, 7vw, 108px); line-height: 0.95; letter-spacing: -0.02em; transition-delay: 0.2s;"
      >
        Clinical Skincare.<br/>
        <em class="not-italic" style="font-style: italic; color: oklch(80% 0.08 78);">Designed for You.</em>
      </h1>
    </div>

    <!-- Right: body + CTAs + steps -->
    <div class="flex flex-col gap-8 pb-2 reveal" style="transition-delay: 0.35s;">

      <!-- Body copy -->
      <p class="font-sans font-light" style="font-size: 15px; line-height: 1.65; color: rgba(255,255,255,0.55); max-width: 340px;">
        A nurse practitioner-founded system that bridges clinical efficacy and clean beauty. Three steps. Five minutes. Results you can photograph.
      </p>

      <!-- CTAs -->
      <div class="flex gap-4 items-center flex-wrap">
        <a
          href="#system"
          class="font-mono text-[10px] tracking-[0.2em] uppercase text-ink transition-colors duration-200"
          style="background: oklch(80% 0.08 78); padding: 14px 32px;"
          onmouseover="this.style.background='oklch(99.5% 0.003 75)'"
          onmouseout="this.style.background='oklch(80% 0.08 78)'"
        >
          Discover the System
        </a>
        <a
          href="/shop"
          class="font-mono text-[10px] tracking-[0.2em] uppercase transition-all duration-200"
          style="color: rgba(255,255,255,0.6); border: 1px solid rgba(255,255,255,0.2); padding: 13px 28px;"
          onmouseover="this.style.borderColor='rgba(255,255,255,0.55)'; this.style.color='rgba(255,255,255,0.9)'"
          onmouseout="this.style.borderColor='rgba(255,255,255,0.2)'; this.style.color='rgba(255,255,255,0.6)'"
        >
          Shop Products
        </a>
      </div>

      <!-- Step indicators -->
      <div style="border-top: 1px solid rgba(255,255,255,0.1); padding-top: 28px; display: flex; gap: 0;">
        {['Cleanse', 'Treat', 'Protect'].map((s, i) => (
          <div
            style={`flex: 1; padding: ${i === 0 ? '0 20px 0 0' : i === 2 ? '0 0 0 20px' : '0 20px'}; ${i < 2 ? 'border-right: 1px solid rgba(255,255,255,0.08);' : ''}`}
          >
            <div class="font-mono text-gold mb-1" style="font-size: 9px; letter-spacing: 0.2em;">0{i + 1}</div>
            <div class="font-display" style="font-size: 18px; font-weight: 400; color: rgba(255,255,255,0.8);">{s}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Scroll nudge -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2">
    <span class="font-mono" style="font-size: 9px; letter-spacing: 0.25em; text-transform: uppercase; color: rgba(255,255,255,0.3);">Scroll</span>
    <div style="width: 1px; height: 40px; background: linear-gradient(to bottom, rgba(255,255,255,0.3), transparent); animation: scrollPulse 2s ease-in-out infinite;"></div>
  </div>
</section>

<script>
  // Hero video entrance
  const video = document.getElementById('hero-video') as HTMLVideoElement | null;
  if (video) {
    const triggerLoaded = () => {
      video.style.transform = 'scale(1)';
      video.style.opacity = '0.55';
    };
    if (video.readyState >= 3) {
      setTimeout(triggerLoaded, 50);
    } else {
      video.addEventListener('canplay', () => setTimeout(triggerLoaded, 50), { once: true });
      setTimeout(triggerLoaded, 800);
    }
  }

  // Hero parallax
  const heroSection = document.getElementById('hero');
  if (video && heroSection) {
    window.addEventListener('scroll', () => {
      const y = window.scrollY;
      if (y < window.innerHeight) {
        video.style.transform = `scale(1) translateY(${y * 0.22}px)`;
      }
    }, { passive: true });
  }
</script>
