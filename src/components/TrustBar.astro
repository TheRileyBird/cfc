---
const items = [
  'Medical-Grade Efficacy',
  'Plant-Based Purity',
  // 'Purity-Tested',
  // 'Louisiana-Made',
  'NP-Founded',
  'Chemist-Formulated',
];
---

<div class="bg-slate-50 border-b border-slate-200 py-4">
  <div class="max-w-7xl mx-auto px-6 lg:px-16">
    <div class="flex flex-wrap items-center justify-center gap-x-7 gap-y-2">
      {items.map((item, i) => (
        <>
          <span class="text-slate-500 text-xs font-semibold tracking-[0.2em] uppercase">{item}</span>
          {i < items.length - 1 && <span class="text-slate-300 hidden sm:block select-none">·</span>}
        </>
      ))}
    </div>
  </div>
</div>
