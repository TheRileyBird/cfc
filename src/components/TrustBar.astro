---
const items = [
  'Medical-Grade Efficacy',
  'Plant-Based Purity',
  'Purity-Tested',
  'Louisiana-Made',
  'NP-Founded',
  'Chemist-Formulated',
];
---

<div class="bg-charcoal-800 py-3.5">
  <div class="max-w-7xl mx-auto px-6 lg:px-16">
    <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-2">
      {items.map((item, i) => (
        <>
          <span class="text-[#E8D5A3]/70 text-[0.65rem] tracking-[0.2em] uppercase font-medium">{item}</span>
          {i < items.length - 1 && <span class="text-[#C9A84C]/30 hidden sm:block text-xs">·</span>}
        </>
      ))}
    </div>
  </div>
</div>
